# Stripe test mode keys — get from dashboard.stripe.com → Developers → API keys
# Copy this file to .env, paste your real keys, save.
# .env is gitignored. Never commit it.

STRIPE_SECRET_KEY=sk_test_your_key_here

# Optional — port (default 8790)
# PORT=8790

# Optional — comma-separated allowed CORS origins (default: open for demo)
# ALLOWED_ORIGINS=https://codepilots.github.io,https://verdantforged.dev
