{
  "$schema": "https://agent-discovery.org/v0.1/agent.schema.json",
  "name": "VerdantForged",
  "description": "A TEE broker for agent workloads. Verifies AMD SEV-SNP attestation before execution, encrypts payloads to the enclave (X25519 + ChaCha20-Poly1305), and uses Stripe PaymentIntents with a verify-then-capture lifecycle so the requester only pays for work that actually ran. Live broker at https://verdant.codepilots.co.uk.",
  "version": "0.1.0",
  "type": "tee_broker",
  "license": "MIT",
  "homepage": "https://verdantforged.pages.dev",
  "agent_instructions": {
    "url": "https://verdantforged.pages.dev/AGENT.md",
    "format": "markdown",
    "alt_urls": [
      "https://verdantforged.pages.dev/.Agent.md"
    ]
  },
  "capabilities": {
    "attestation": "amd-sev-snp",
    "submit_job": true,
    "register_skill": true,
    "fetch_discover": true,
    "encrypted_payload": "x25519-hkdf-sha256-chacha20poly1305-v1",
    "payment": "stripe-paymentintent-verify-then-capture"
  },
  "endpoints": {
    "discover":       "https://verdant.codepilots.co.uk/v1/discover",
