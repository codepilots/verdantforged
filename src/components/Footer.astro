---
/**
 * Footer — broker-as-product voice.
 *
 * The footer is the last thing the user reads. It restates the four
 * pillars in one line, names the audit document, and keeps the sponsor
 * credits as text only (pending brand kit audit).
 *
 * Updated 2026-06-29: navigation to the four pillar deep-dive pages
 * and the /agents/ page, in addition to the standard resources.
 */

const year = new Date().getFullYear();

const stack = [
  { name: 'NVIDIA NemoClaw',   detail: 'SEV-SNP attestation',     color: 'text-verdigris-deep' },
  { name: 'Stripe PaymentIntent', detail: 'verify-then-capture', color: 'text-copper' },
  { name: 'Nous Hermes',       detail: 'inference runtime',         color: 'text-verdigris' },
  { name: 'Hermes Agent',      detail: 'agent runtime',             color: 'text-moss' },
];

const pillars = [
  { name: 'Attestation',  href: '/attestation' },
  { name: 'Security',     href: '/security'    },
  { name: 'Sandboxing',   href: '/sandboxing'  },
  { name: 'Payment',      href: '/payment'     },
];
---

<footer class="bg-bark text-bg/85 mt-section">
  <div class="vf-container py-30">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Brand -->
      <div class="md:col-span-5">
        <div class="font-display text-display-sm font-semibold text-bg">
          VerdantForged
        </div>
        <p class="mt-6 text-body-sm text-bg/70 max-w-md">
          The broker for attested agent execution. Four pillars —
          attestation, security, sandboxing, payment — enforced by
          hardware and by Stripe, not by the operator.
        </p>
        <p class="mt-8 text-caption text-bg/50 font-mono uppercase tracking-widest">
          Open source · MIT
        </p>
      </div>

      <!-- Four pillars -->
      <div class="md:col-span-3">
        <p class="vf-eyebrow text-bg/50">Four pillars</p>
        <ul class="mt-6 space-y-3 text-body-sm">
          {pillars.map((p) => (
            <li>
              <a href={p.href} class="text-bg/85 hover:text-copper transition-colors">
                {p.name}
              </a>
            </li>
          ))}
          <li class="pt-3 border-t border-bg/15 mt-3">
            <a href="/agents" class="text-bg/85 hover:text-copper transition-colors">
              For agents →
            </a>
          </li>
        </ul>
      </div>

      <!-- Stack credits (text only) -->
      <div class="md:col-span-4">
        <p class="vf-eyebrow text-bg/50">Stands on</p>
        <ul class="mt-6 space-y-3 text-body-sm">
          {stack.map((item) => (
            <li>
              <span class={item.color}>●</span>
              <span class="ml-3">{item.name}</span>
              <span class="ml-2 text-bg/50 text-caption">{item.detail}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Resources strip -->
    <div class="mt-20 pt-10 border-t border-bg/15 grid grid-cols-2 sm:grid-cols-4 gap-4 text-caption">
      <a href="/AGENT.md" class="text-bg/85 hover:text-copper transition-colors">AGENT.md</a>
      <a
        href="https://github.com/codepilots/tee-broker-pattern/blob/main/SPEC.md"
        class="text-bg/85 hover:text-copper transition-colors"
      >Protocol spec</a>
      <a
        href="https://github.com/codepilots/tee-broker-pattern/blob/main/SECURITY_AUDIT.md"
        class="text-bg/85 hover:text-copper transition-colors"
      >Security audit</a>
      <a
        href="https://github.com/codepilots/tee-broker-pattern"
        class="text-bg/85 hover:text-copper transition-colors"
      >Source code</a>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row justify-between gap-4 text-caption text-bg/50">
      <p>© {year} VerdantForged · Built by Autumn</p>
      <p class="font-mono uppercase tracking-widest">
        NVIDIA × Stripe × Nous Research · Hackathon 2026
      </p>
    </div>
  </div>
</footer>
