---
/**
 * Pillars — the four engineering pillars of the broker.
 *
 * Each pillar: eyebrow (PILLAR 0X), one-line promise, a 2-3 line body, a
 * "what stops what" mini-table, an evidence footer, and a "Read the deep
 * dive" link to the per-pillar page. Layout is a 2x2 grid on desktop,
 * stacked on mobile. The pillars section is the centerpiece of the site
 * — it IS the pitch.
 *
 * Pillar order (locked 2026-06-29): Attestation → Security → Sandboxing → Payment.
 * The order tells the story: silicon identity first, then crypto, then
 * execution isolation, then the payment rail that ties it together.
 *
 * Updated 2026-06-29: each pillar now links to its own /<pillar> deep-dive
 * page written for non-experts.
 */

interface AttackRow {
  attack: string;
  fix: string;
}

interface Pillar {
  n: string;
  eyebrow: string;
  headline: string;
  body: string;
  // Link to the deep-dive page
  deepDiveHref: string;
  deepDiveLabel: string;
  // For the inline SVG diagram
  diagram: 'attestation' | 'security' | 'sandboxing' | 'payment';
  attacks: AttackRow[];
  // Where the audit evidence lives, shown as a footer line
  evidence: string;
}

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const pillars: Pillar[] = [
  {
    n: '01',
    eyebrow: 'Pillar 01 · Attestation',
    headline: 'Trust the measured worker, not the operator.',
    body: 'Workloads run on a dedicated m6a.xlarge EC2 worker with AMD SEV-SNP memory encryption + remote attestation enabled. The worker exposes the 1184-byte signed SNP report, measurement, report_data, policy hash, certificate chain, and enclave X25519 public key. The broker checks the report signature against the supplied VCEK/VLEK certificate; requester-side verifiers perform the full AMD-root-chain and measurement policy checks.',
    deepDiveHref: `${base}attestation/`,
    deepDiveLabel: 'Read the attestation deep dive →',
    diagram: 'attestation',
    attacks: [
      { attack: 'Operator swaps the runtime',  fix: 'Measurement mismatch — the report is signed by silicon the operator doesn\'t control' },
      { attack: 'Replay or unrelated worker identity', fix: 'Worker binding and report_data tie the advertised key to the attestation path' },
      { attack: 'Fake attestation payload',     fix: 'Broker-side report signature check plus requester-side AMD chain validation' },
    ],
    evidence: 'SNP report VCEK/VLEK cert chain + `_verify_snp_quote_signature` (1184-byte length check + RSA-PSS verify against supplied cert) — see /attestation/ for the full check matrix',
  },
  {
    n: '02',
    eyebrow: 'Pillar 02 · Security',
    headline: 'Encryption to silicon, not to policy.',
    body: 'Production payloads are encrypted to the worker\'s X25519 public key before they leave the requester\'s machine — using x25519-hkdf-sha256-chacha20poly1305-v1 (X25519 ECDH, HKDF-SHA256 KDF, ChaCha20-Poly1305 AEAD, AAD bound to "verdantforged-input"). Decryption happens inside the measured worker boundary. The result is encrypted back to the requester\'s pubkey on the way out.',
    deepDiveHref: `${base}security/`,
    deepDiveLabel: 'Read the security deep dive →',
    diagram: 'security',
    attacks: [
      { attack: 'Broker reads production input',  fix: 'Payload encrypted to the worker key before submission' },
      { attack: 'Broker changes result metadata', fix: 'Worker and broker signatures bind result/input/skill hashes' },
      { attack: 'Result sent to the wrong requester', fix: 'Result encryption uses the requester result public key' },
      { attack: 'Payload replayed in another channel', fix: 'HKDF/AAD channel separation and per-job envelopes' },
    ],
    evidence: 'x25519-hkdf-sha256-chacha20poly1305-v1 — same envelope format used for input, artifacts, and result channels (distinct AAD per channel)',
  },
  {
    n: '03',
    eyebrow: 'Pillar 03 · Sandboxing',
    headline: 'Jobs run through explicit worker dispatch paths.',
    body: 'The live worker dispatch tree is explicit: registered WASM skills run via wasmtime with manifest limits, tool-loop skills use the tool-calling path, prompt-template jobs run through the NemoClaw sandbox (`nemohermes exec`), and legacy host fallback is only used where explicitly implemented. Worker signatures and broker signatures bind result metadata after execution.',
    deepDiveHref: `${base}sandboxing/`,
    deepDiveLabel: 'Read the sandboxing deep dive →',
    diagram: 'sandboxing',
    attacks: [
      { attack: 'Skill runs forever (DoS)',     fix: 'Fuel limit (manifest up to 10⁹) + wall-clock timeout (default 30s)' },
      { attack: 'Prompt job calls arbitrary network directly', fix: 'NemoClaw/OpenShell policy and broker-mediated LLM route' },
      { attack: 'Skill tampers with the binary', fix: 'Worker recomputes SHA-256(envelope.skill_hash) and rejects mismatches before wasmtime starts' },
      { attack: 'Skill overflows output buffer', fix: '50 MiB per-file + 100 MiB total output caps, checked before S3 upload' },
    ],
    evidence: 'worker/poller.py execute_in_envelope + dispatch_to_sandbox; skill manifest defaults/hard caps in daemon.py validate_skill_manifest',
  },
  {
    n: '04',
    eyebrow: 'Pillar 04 · Payment',
    headline: 'Stripe capture happens only after job finalization.',
    body: 'Payment arrives as a Stripe ACS Shared Payment Token or legacy PaymentIntent. The broker verifies or creates a PaymentIntent before accepting the job. On completed, _finalize_job captures the actual cost (lease + tokens, padded to the configured minimum). On failed or timeout, it refunds. On an underfunded live job, it pauses into awaiting_topup and surfaces shortfall_cents.',
    deepDiveHref: `${base}payment/`,
    deepDiveLabel: 'Read the payment deep dive →',
    diagram: 'payment',
    attacks: [
      { attack: 'Operator pockets the hold',            fix: 'Funds sit in Stripe against the requester\'s card, not in the operator\'s account' },
      { attack: 'Operator captures before work ends',    fix: 'Capture only fires from _finalize_job after the worker outbox result is processed' },
      { attack: 'Operator fabricates a successful run',  fix: 'Result envelope carries a broker Ed25519 signature independent of the worker\'s; verifiable without the broker' },
      { attack: 'Operator overcharges on actual cost',   fix: 'Cost is a function of lease-seconds + tokens (BROKER_MIN_CAPTURE_CENTS pads only below per-currency floors); Stripe receipt is published' },
    ],
    evidence: 'Stripe ACS Shared Payment Token + PaymentIntent verify-then-capture lifecycle — see /payment-flow for the 4 paths and /payment for the engineering view',
  },
];
---

<section
  id="pillars"
  class="vf-container section"
  aria-labelledby="pillars-heading"
>
  <p class="vf-eyebrow">The four pillars</p>
  <h2 id="pillars-heading" class="vf-heading-section mt-6 max-w-4xl">
    What the broker actually delivers.
  </h2>
  <p class="vf-body-lead mt-8 max-w-2xl">
    The guarantees below are made by the hardware (SEV-SNP), the crypto (X25519
    + ChaCha20-Poly1305), the runtime (fuel-limited, default-DENY), and the
    payment rail (Stripe PaymentIntent). Not by the operator running the broker.
    Each pillar has a deep-dive page — click through for the beginner-friendly
    explainer, the attack/defense matrix, and the code.
  </p>

  <div class="mt-20 grid grid-cols-1 lg:grid-cols-2 gap-6 max-w-6xl">
    {pillars.map((p) => (
      <article class="vf-card flex flex-col" aria-labelledby={`pillar-${p.n}-heading`}>
        <!-- Pillar header: number + eyebrow -->
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="vf-eyebrow text-ink-soft">{p.eyebrow}</p>
            <h3
              id={`pillar-${p.n}-heading`}
              class="mt-3 text-display-sm font-display font-semibold text-ink vf-text-balance"
            >
              {p.headline}
            </h3>
          </div>
          <!-- Diagram: small inline SVG, kept minimal -->
          <div class="shrink-0 w-16 h-16" aria-hidden="true">
            <svg viewBox="0 0 64 64" class="w-full h-full">
              {p.diagram === 'attestation' && (
                <g>
                  <rect x="16" y="10" width="32" height="44" rx="3" fill="none" stroke="#3b2e23" stroke-width="1.5"/>
                  <text x="32" y="26" text-anchor="middle" font-size="6" font-family="JetBrains Mono" fill="#2d6a4f">SEV</text>
                  <text x="32" y="34" text-anchor="middle" font-size="6" font-family="JetBrains Mono" fill="#2d6a4f">SNP</text>
                  <line x1="20" y1="42" x2="44" y2="42" stroke="#b87333" stroke-width="1.5"/>
                  <text x="32" y="50" text-anchor="middle" font-size="5" font-family="JetBrains Mono" fill="#b87333">0x9af…</text>
                  <circle cx="32" cy="32" r="20" fill="none" stroke="#2d6a4f" stroke-width="0.8" opacity="0.4">
                    <animate attributeName="r" values="18;26;18" dur="3s" repeatCount="indefinite"/>
                  </circle>
                </g>
              )}
              {p.diagram === 'security' && (
                <g>
                  <rect x="6" y="22" width="22" height="20" rx="2" fill="none" stroke="#3b2e23" stroke-width="1.5"/>
                  <rect x="36" y="22" width="22" height="20" rx="2" fill="none" stroke="#3b2e23" stroke-width="1.5"/>
                  <text x="17" y="35" text-anchor="middle" font-size="6" font-family="JetBrains Mono" fill="#3b2e23">E(key)</text>
                  <text x="47" y="35" text-anchor="middle" font-size="6" font-family="JetBrains Mono" fill="#3b2e23">E(data)</text>
                  <path d="M 28 32 L 36 32" stroke="#b87333" stroke-width="1.5"/>
                  <path d="M 28 35 L 36 35" stroke="#b87333" stroke-width="1.5" stroke-dasharray="2 2"/>
                  <text x="32" y="14" text-anchor="middle" font-size="5" font-family="JetBrains Mono" fill="#5fa39a">enclave</text>
                </g>
              )}
              {p.diagram === 'sandboxing' && (
                <g>
                  <rect x="8" y="8" width="48" height="48" rx="4" fill="none" stroke="#2d6a4f" stroke-width="1.5"/>
                  <text x="32" y="24" text-anchor="middle" font-size="7" font-family="JetBrains Mono" fill="#2d6a4f" font-weight="600">WASM</text>
                  <line x1="14" y1="30" x2="50" y2="30" stroke="#5fa39a" stroke-width="0.5" opacity="0.5"/>
                  <line x1="14" y1="44" x2="50" y2="44" stroke="#5fa39a" stroke-width="0.5" opacity="0.5"/>
                  <rect x="14" y="36" width="36" height="4" rx="1" fill="none" stroke="#3b2e23" stroke-width="0.8"/>
                  <rect x="14" y="36" width="20" height="4" rx="1" fill="#b87333">
                    <animate attributeName="width" values="0;36;0" dur="4s" repeatCount="indefinite"/>
                  </rect>
                  <text x="32" y="51" text-anchor="middle" font-size="4" font-family="JetBrains Mono" fill="#4a4a45">fuel</text>
                </g>
              )}
              {p.diagram === 'payment' && (
                <g>
                  <circle cx="14" cy="32" r="8" fill="none" stroke="#3b2e23" stroke-width="1.5"/>
                  <text x="14" y="35" text-anchor="middle" font-size="8" font-family="JetBrains Mono" fill="#3b2e23">$</text>
                  <circle cx="50" cy="32" r="8" fill="none" stroke="#2d6a4f" stroke-width="1.5"/>
                  <text x="50" y="35" text-anchor="middle" font-size="8" font-family="JetBrains Mono" fill="#2d6a4f">$</text>
                  <rect x="26" y="20" width="12" height="14" rx="1" fill="none" stroke="#b87333" stroke-width="1.5"/>
                  <path d="M 28 20 V 17 a 4 4 0 0 1 8 0 V 20" fill="none" stroke="#b87333" stroke-width="1.5"/>
                  <text x="32" y="30" text-anchor="middle" font-size="6" font-family="JetBrains Mono" fill="#b87333">PI</text>
                  <path d="M 22 42 Q 32 50 42 42" fill="none" stroke="#5fa39a" stroke-width="1" stroke-dasharray="2 2"/>
                  <text x="32" y="56" text-anchor="middle" font-size="4" font-family="JetBrains Mono" fill="#5fa39a">refund</text>
                </g>
              )}
            </svg>
          </div>
        </div>

        <!-- Pillar body -->
        <p class="mt-6 text-body text-ink-soft vf-text-pretty max-w-prose-vf">
          {p.body}
        </p>

        <!-- "What stops what" mini-table -->
        <div class="mt-8 border-t border-moss/30 pt-6">
          <p class="vf-eyebrow text-ink-soft">What stops what</p>
          <dl class="mt-4 space-y-3">
            {p.attacks.map((row) => (
              <div class="grid grid-cols-1 sm:grid-cols-5 gap-x-4 gap-y-1">
                <dt class="sm:col-span-2 text-body-sm text-ink vf-text-pretty">
                  {row.attack}
                </dt>
                <dd class="sm:col-span-3 text-body-sm text-ink-soft vf-text-pretty">
                  <span class="text-verdigris-deep mr-2" aria-hidden="true">✓</span>
                  {row.fix}
                </dd>
              </div>
            ))}
          </dl>
        </div>

        <!-- Evidence footer -->
        <p class="mt-6 text-caption text-ink-soft font-mono leading-relaxed border-t border-moss/30 pt-4">
          <span class="text-copper-deep">evidence — </span>
          {p.evidence}
        </p>

        <!-- Deep dive link -->
        <a
          href={p.deepDiveHref}
          class="mt-6 inline-flex items-center gap-2 text-body-sm text-copper-deep font-medium hover:text-copper transition-colors"
        >
          {p.deepDiveLabel}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </article>
    ))}
  </div>

  <!-- For agents callout -->
  <div class="mt-16 max-w-3xl vf-card border-verdigris/40">
    <p class="vf-eyebrow text-verdigris-deep">For agents</p>
    <p class="mt-3 text-body text-ink vf-text-pretty">
      The four pillars above are the engineering pitch. The
      <a href={`${base}agents/`} class="vf-link">/agents page</a> is the operator/agent
      setup: how to set up a broker, how to submit jobs to the live test
      broker at <code class="font-mono text-caption">verdant.codepilots.co.uk</code>,
      and how to register a custom skill.
    </p>
  </div>

  <!-- Audit footnote -->
  <p class="mt-12 max-w-2xl mx-auto text-center text-body text-ink-soft">
    The broker is the marketplace, the sandbox, and the wallet.
    The guarantees are made by
    <span class="text-verdigris-deep">NVIDIA NemoClaw</span>,
    <span class="text-copper-deep">Stripe</span>, and
    <span class="text-ink">the protocol itself</span> —
    not by us.
  </p>
</section>
