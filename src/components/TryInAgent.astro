---
/**
 * TryInAgent — the install CTA, three entry points.
 *
 *   A. Read the spec + audit    ← primary path for reviewers
 *   B. Paste prompt             ← for users with their own Hermes install
 *   C. Direct download          ← AGENT.md
 *
 * The Pyodide / "Try in browser" path was removed with the marketplace
 * pivot (2026-06-29). The broker is the product; install-on-your-own-machine
 * is the right path for that.
 *
 * Updated 2026-06-30: the prior prompt hardcoded
 * "https://verdantforged.pages.dev/AGENT.md" — that host does not resolve
 * (DNS NXDOMAIN). The canonical AGENT.md lives at /public/AGENT.md and is
 * served from this site directly. Also updated the GitHub link, which
 * previously pointed at github.com/codepilots/tee-broker-pattern (404) —
 * that repo isn't public yet, so reviewers should use the live broker's
 * /docs endpoint and /api/openapi.json instead.
 */

const hermesPrompt = `Read /AGENT.md from the VerdantForged broker at https://verdant.codepilots.co.uk (live test broker) and walk me through the four pillars: attestation, security, sandboxing, payment.`;
---

<section id="try" class="vf-container section" aria-labelledby="try-heading">
  <p class="vf-eyebrow">Run the broker</p>
  <h2 id="try-heading" class="vf-heading-section mt-6 max-w-4xl">
    Three ways to install it.
  </h2>
  <p class="vf-body-lead mt-8 max-w-2xl">
    No signup. No API key. No vendor lock-in. Pick the path that matches
    how you already work.
  </p>

  <div class="mt-20 max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- A: Spec + audit -->
    <div class="vf-card relative border-verdigris/40">
      <span class="vf-eyebrow absolute top-6 right-6 text-verdigris-deep">Start here</span>
      <h3 class="text-display-sm font-display font-semibold text-ink">
        Read the spec + audit
      </h3>
      <p class="text-body text-ink-soft mt-4">
        The protocol is the source of truth, the audit is the receipt. Read
        both — the audit lists what's tested and what's still on the
        roadmap.
      </p>
      <div class="mt-8 flex flex-col gap-3">
        <a
          href="/docs"
          class="vf-button w-full justify-center"
        >
          Open /docs
        </a>
        <a
          href="/attestation/"
          class="vf-button-ghost w-full justify-center"
        >
          Open attestation deep dive
        </a>
        <a
          href="/security/"
          class="vf-button-ghost w-full justify-center"
        >
          Open security deep dive
        </a>
      </div>
      <p class="text-caption text-ink-soft mt-4 text-center font-mono">
        30+ verify-*.py tests · live at verdant.codepilots.co.uk
      </p>
    </div>

    <!-- B: Paste prompt -->
    <div class="vf-card">
      <h3 class="text-display-sm font-display font-semibold text-ink">
        Paste into chat
      </h3>
      <p class="text-body text-ink-soft mt-4">
        Copy this prompt into your Hermes chat. The agent will fetch
        AGENT.md and walk through the four pillars.
      </p>

      <div class="mt-6 relative">
        <textarea
          id="hermes-prompt"
          readonly
          rows="3"
          class="w-full p-4 bg-bark text-bg font-mono text-body-sm rounded-lg resize-none focus:outline-none"
          aria-label="Hermes prompt to install the VerdantForged broker"
        >{hermesPrompt}</textarea>
        <button
          type="button"
          id="copy-prompt-btn"
          class="absolute bottom-3 right-3 px-3 py-1.5 bg-copper text-bg text-caption rounded-md hover:bg-copper-deep transition-colors"
        >
          Copy
        </button>
      </div>
    </div>

    <!-- C: Direct download -->
    <div class="vf-card">
      <h3 class="text-display-sm font-display font-semibold text-ink">
        Direct download
      </h3>
      <p class="text-body text-ink-soft mt-4">
        For users with their own agent runtime. Right-click → Save Link As,
        or point your crawler at it.
      </p>
      <a
        href="/AGENT.md"
        download
        class="vf-button mt-8 w-full justify-center"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 1v10m0 0L4 7m4 4l4-4M2 14h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download AGENT.md
      </a>
      <p class="text-caption text-ink-soft mt-4 text-center">
        plain markdown · no dependencies
      </p>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-prompt-btn');
  const ta  = document.getElementById('hermes-prompt') as HTMLTextAreaElement | null;
  if (btn && ta) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(ta.value);
        const original = btn.textContent;
        btn.textContent = 'Copied ✓';
        btn.classList.add('bg-verdigris-deep');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('bg-verdigris-deep');
        }, 1800);
      } catch {
        ta.select();
        document.execCommand('copy');
      }
    });
  }
</script>
