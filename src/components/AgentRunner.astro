---
/**
 * AgentRunner — Hermes Portable full-page runner (v3)
 *
 * Layout (top → bottom, the user requested order):
 *
 *   ┌─ Banner (sticky) ────────────────────────────────────┐
 *   │ broker connection · session id · cost ticker · status │
 *   └────────────────────────────────────────────────────────┘
 *
 *   ┌─ Chat window (scrollable, bounded height) ────────────┐
 *   │                                                      │
 *   │   [user] how does the broker work?                    │
 *   │                                                      │
 *   │   [hermes portable] § Three Agents — The VerdantForged│
 *   │   protocol routes skill calls through an attested...  │
 *   │                                                      │
 *   │   [tool] broker_session · action=open · python-3.11   │
 *   │                                                      │
 *   │   [hermes portable] Session opened. Now running your  │
 *   │   query inside the enclave.                           │
 *   │                                                      │
 *   └────────────────────────────────────────────────────────┘
 *
 *   ┌─ Prompt input (fixed bottom) ──────────────────────────┐
 *   │ [  e.g. how does stripe escrow work?     ] [ Send ]   │
 *   └────────────────────────────────────────────────────────┘
 *
 * The page DOES NOT require a button press. Hermes Portable boots
 * itself when the user focuses the prompt input (Pyodide + Hermes
 * Python) and when the user makes any mouse/key/scroll activity
 * (WebLLM model download). Both happen in the background.
 *
 * The broker session is opened by the agent itself, not by the page
 * UI — when Hermes decides the user's request needs real compute, it
 * invokes the broker_session skill, which fires a DOM event the JS
 * dashboard listens for. The page UI only handles the session
 * The actual layout lives in AgentRunner.astro (banner → chat → input).
  *
  * NOTE: AgentRunner.astro is a fragment, not a full document — the
  * surrounding page (agent.astro) provides the <BaseLayout>. Putting
  * a second <BaseLayout> here would cause nested <html>/<body>/<head>
  * and break the bundled CSS.
  */
 ---

 <header
    id="vf-banner"
    class="sticky top-0 z-20 bg-bg/95 backdrop-blur-sm border-b border-moss/30"
    aria-label="Broker session banner"
  >
    <div class="vf-container flex flex-wrap items-center gap-x-6 gap-y-2 py-3">
      <!-- Connection pill -->
      <div class="flex items-center gap-2">
        <span
          id="vf-banner-pulse"
          class="w-2 h-2 rounded-full bg-ink-soft"
          aria-hidden="true"
        ></span>
        <code
          id="vf-banner-status"
          class="font-mono text-caption uppercase tracking-widest text-ink-soft"
          data-role="engine-status"
          data-state="idle"
        >awaiting activity</code>
      </div>

      <!-- Session id -->
      <div class="flex items-center gap-2">
        <span class="vf-eyebrow text-ink-soft">session</span>
        <code
          id="vf-banner-session"
          class="font-mono text-caption text-ink-soft"
        >none</code>
      </div>

      <!-- Cost ticker -->
      <div class="flex items-baseline gap-2">
        <span class="vf-eyebrow text-ink-soft">spent</span>
        <code
          id="vf-banner-cost"
          class="font-mono text-body text-copper-deep tabular-nums"
          data-role="total"
        >$0.0000</code>
      </div>

      <!-- Lease countdown -->
      <div class="flex items-baseline gap-2">
        <span class="vf-eyebrow text-ink-soft">remaining</span>
        <code
          id="vf-banner-clock"
          class="font-mono text-body text-ink tabular-nums"
          data-role="clock"
        >0:00</code>
      </div>

      <!-- Right side: close session -->
      <button
        type="button"
        id="vf-banner-close"
        data-action="vf-agent-close"
        class="ml-auto vf-button-ghost text-caption uppercase tracking-widest opacity-60"
        disabled
      >
        Close session
      </button>
    </div>
  </header>

  <!-- Chat window — bounded height, native scroll, role=log -->
  <main class="vf-container">
    <section
      id="vf-chat"
      aria-label="Chat with Hermes Portable"
      class="mt-6 mb-6"
    >
      <div
        id="vf-chat-stream"
        class="max-h-[60vh] overflow-y-auto rounded-2xl border border-moss/30 bg-moss/5 p-6 space-y-6"
        data-role="log"
        role="log"
        aria-live="polite"
      >
        <!-- First message is rendered by the page script once Hermes is ready. -->
        <p class="text-ink-soft text-body-sm font-mono text-center">
          Hermes Portable is starting up. The first message takes a moment while WebLLM and Pyodide finish warming.
        </p>
      </div>
    </section>

    <!-- Prompt input — fixed at the bottom of the viewport -->
    <form
      id="vf-prompt-form"
      class="sticky bottom-0 bg-bg/95 backdrop-blur-sm border-t border-moss/30 -mx-6 sm:-mx-8 lg:-mx-12 px-6 sm:px-8 lg:px-12 py-4"
      onsubmit="return false"
      aria-label="Send a prompt to Hermes Portable"
    >
      <label for="vf-prompt-input" class="sr-only">Ask Hermes Portable</label>
      <div class="flex items-stretch gap-3">
        <input
          type="text"
          id="vf-prompt-input"
          data-role="prompt-input"
          placeholder="Ask Hermes Portable anything — it'll open a broker session if needed."
          autocomplete="off"
          spellcheck="true"
          class="flex-1 bg-bg border border-moss rounded-full px-5 py-3 font-sans text-body text-ink placeholder:text-ink-soft focus:border-copper focus:outline-none transition-colors"
        />
        <button
          type="submit"
          data-action="vf-agent-prompt"
          class="vf-button"
        >
          Send
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      <p class="mt-2 text-caption text-ink-soft font-mono">
        Hermes decides when to open a broker session. You don't have to click anything.
      </p>
    </form>
  </main>

<script>
  /**
   * Page-level glue:
   *   1. Install auto-launch (warms WebLLM on activity, boots Hermes
   *      Portable on chat-input focus).
   *   2. Listen for vf:engine-state and update the banner pill.
   *   3. Listen for vf:broker-session and drive the dashboard
   *      (open/extend/close).
   *   4. Wire prompt submit → Hermes Portable chat() → render the
   *      response in the chat window.
   */

  import { installAutoLaunch, getPortableHermes } from '~/lib/auto-launch';
  import { getEngineState } from '~/lib/webllm-engine';
  import { createDashboard } from '~/lib/session-dashboard';
  import type { ChatMessage } from '~/lib/portable-hermes';

  installAutoLaunch();

  // ── Element handles ──────────────────────────────────────────────
  const banner        = document.getElementById('vf-banner');
  const bannerPulse   = document.getElementById('vf-banner-pulse');
  const bannerStatus  = document.getElementById('vf-banner-status');
  const bannerSession = document.getElementById('vf-banner-session');
  const bannerCost    = document.getElementById('vf-banner-cost');
  const bannerClock   = document.getElementById('vf-banner-clock');
  const bannerClose   = document.getElementById('vf-banner-close') as HTMLButtonElement | null;
  const chatStream    = document.getElementById('vf-chat-stream');
  const promptForm    = document.getElementById('vf-prompt-form') as HTMLFormElement | null;
  const promptInput   = document.getElementById('vf-prompt-input') as HTMLInputElement | null;

  // ── Render engine state into the banner pill ────────────────────
  function renderBanner(state: ReturnType<typeof getEngineState>): void {
    if (!bannerStatus) return;
    const { status, progress, backend, error } = state;
    let label = '';
    let cls = 'bg-ink-soft';
    switch (status) {
      case 'idle':
        label = 'awaiting activity';
        cls = 'bg-ink-soft';
        break;
      case 'loading':
        label = `warming ${Math.round(progress * 100)}% · ${backend}`;
        cls = 'bg-copper animate-pulse';
        break;
      case 'ready':
        label = `ready · ${backend}`;
        cls = 'bg-verdigris-deep';
        break;
      case 'fallback':
        label = 'fallback · python mock';
        cls = 'bg-copper-deep';
        break;
      case 'error':
        label = `error · ${error ?? 'unknown'}`;
        cls = 'bg-copper-deep';
        break;
    }
    if (bannerStatus) bannerStatus.textContent = label;
    if (bannerPulse) bannerPulse.className = `w-2 h-2 rounded-full ${cls}`;
    if (bannerStatus) bannerStatus.dataset.state = status;
  }

  window.addEventListener('vf:engine-state', ((e: CustomEvent) => {
    renderBanner(e.detail);
  }) as EventListener);
  renderBanner(getEngineState());

  // ── Create the dashboard (drives banner cost/clock via DOM contract) ──
  //
  // The dashboard module's render() updates elements matching
  // data-role="clock", data-role="total" etc. within the document —
  // because the banner is sticky-top and uses the same data-roles,
  // it auto-binds without a custom hook. Verify after build.
  const dashboard = createDashboard({
    rootId: 'vf-agent',
    maxBudgetUsd: 0.50,
    costPerMin: 0.0133,
    skillCostUsd: 0.0050,
    leaseSeconds: 300,
    extendSeconds: 120,
    sessionShort: 'sess_demo',
    environment: 'python-3.11-base',
    onSkillCall: async (prompt: string) => {
      // Hand the prompt to Hermes Portable. The chat() method returns
      // the agent's response + any tool calls it made.
      const hermes = await getPortableHermes();
      const history: ChatMessage[] = [
        { role: 'user', content: prompt },
      ];
      const result = await hermes.chat(history);
      // Note: the result.toolCalls array tracks what Hermes decided
      // to invoke (e.g. broker_session). The dashboard session is
      // already opened/extended/closed by the vf:broker-session
      // listener below; we just return the chat result.
      return {
        summary: result.content || '(no response)',
        llmCost: result.llmCost,
        tokens: result.tokens,
      };
    },
  });

  // ── React when Hermes decides to open a broker session ───────────
  window.addEventListener('vf:broker-session', ((e: CustomEvent) => {
    const { action, env } = e.detail as { action: 'open' | 'extend' | 'close'; env?: string };
    if (action === 'open' && !dashboard.isActive()) {
      dashboard.open();
      appendChatBubble('tool', `Hermes opened a broker session · env=${env ?? 'python-3.11-base'}`);
    } else if (action === 'extend' && dashboard.isActive()) {
      dashboard.extend();
      appendChatBubble('tool', 'Hermes extended the session');
    } else if (action === 'close' && dashboard.isActive()) {
      dashboard.close('Hermes closed the session');
      appendChatBubble('tool', 'Hermes closed the broker session');
    }
  }) as EventListener);

  // ── React when any skill runs (for the transcript) ───────────────
  window.addEventListener('vf:skill-called', ((e: CustomEvent) => {
    const { name, args } = e.detail as { name: string; args: Record<string, any> };
    const argsStr = Object.entries(args)
      .map(([k, v]) => `${k}=${JSON.stringify(v)}`)
      .join(' · ');
    appendChatBubble('tool', `⚙ ${name}${argsStr ? ` · ${argsStr}` : ''}`);
  }) as EventListener);

  // ── Update banner session id when dashboard opens ────────────────
  const origOpen = dashboard.open;
  dashboard.open = function () {
    origOpen();
    if (bannerSession) {
      const id = `sess_${Math.random().toString(36).slice(2, 10)}`;
      bannerSession.textContent = id;
    }
    if (bannerClose) {
      bannerClose.disabled = false;
      bannerClose.classList.remove('opacity-60');
    }
  };
  const origClose = dashboard.close;
  dashboard.close = function (reason?: string) {
    origClose(reason);
    if (bannerSession) bannerSession.textContent = 'none';
    if (bannerClose) {
      bannerClose.disabled = true;
      bannerClose.classList.add('opacity-60');
    }
  };

  // ── Banner close button ─────────────────────────────────────────
  if (bannerClose) {
    bannerClose.addEventListener('click', () => {
      dashboard.close('User closed');
    });
  }

  // ── Chat rendering helpers ──────────────────────────────────────
  type BubbleRole = 'user' | 'agent' | 'tool';
  function appendChatBubble(role: BubbleRole, text: string): void {
    if (!chatStream) return;
    // Clear the placeholder on first real message.
    const placeholder = chatStream.querySelector<HTMLElement>('[data-role="chat-placeholder"]');
    if (placeholder) placeholder.remove();

    const bubble = document.createElement('div');
    bubble.className = 'vf-chat-bubble';
    bubble.dataset.role = role;

    const author = document.createElement('p');
    author.className = 'vf-eyebrow text-ink-soft';
    author.textContent =
      role === 'user' ? 'you' :
      role === 'agent' ? 'hermes portable' :
      'system';

    const body = document.createElement('p');
    body.className = 'mt-1 text-body text-ink whitespace-pre-wrap';
    body.textContent = text;

    bubble.appendChild(author);
    bubble.appendChild(body);
    chatStream.appendChild(bubble);

    // Auto-scroll to bottom.
    chatStream.scrollTop = chatStream.scrollHeight;
  }

  // ── Prompt submission ───────────────────────────────────────────
  let _inFlight = false;
  async function handleSubmit(e: Event): Promise<void> {
    e.preventDefault();
    if (_inFlight) return;
    const text = promptInput?.value?.trim() ?? '';
    if (!text) return;
    if (promptInput) promptInput.value = '';
    _inFlight = true;
    appendChatBubble('user', text);
    appendChatBubble('agent', '…');
    const lastBubble = chatStream?.lastElementChild as HTMLElement | null;
    try {
      const hermes = await getPortableHermes();
      const history: ChatMessage[] = [{ role: 'user', content: text }];
      const result = await hermes.chat(history);
      // Replace the "…" placeholder with the actual response.
      if (lastBubble) {
        const body = lastBubble.querySelector('p:nth-of-type(2)') as HTMLElement | null;
        if (body) {
          body.textContent = result.content || '(no response)';
        }
      }
      // Update session id display when a session is opened.
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      if (lastBubble) {
        const body = lastBubble.querySelector('p:nth-of-type(2)') as HTMLElement | null;
        if (body) {
          body.textContent = `Error: ${msg}`;
        }
      }
    } finally {
      _inFlight = false;
    }
  }

  if (promptForm) {
    promptForm.addEventListener('submit', handleSubmit);
  }
</script>

<style>
  .vf-chat-bubble {
    padding: 0.75rem 0;
  }
  .vf-chat-bubble[data-role="user"] {
    border-left: 2px solid #b87333;
    padding-left: 1rem;
  }
  .vf-chat-bubble[data-role="agent"] {
    border-left: 2px solid #2d6a4f;
    padding-left: 1rem;
  }
  .vf-chat-bubble[data-role="tool"] {
    border-left: 2px solid #8a9a5b;
    padding-left: 1rem;
    background: rgba(138, 154, 91, 0.05);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin: 0 -1rem;
  }
  .vf-chat-bubble[data-role="tool"] p:nth-of-type(2) {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    color: #4a4a45;
  }
</style>