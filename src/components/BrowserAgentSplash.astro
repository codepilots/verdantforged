---
/**
 * BrowserAgentSplash — Pyodide load-on-click overlay
 *
 * Lazy-loads a cutdown Hermes Agent (Python via Pyodide WASM) when the user
 * clicks the hero CTA. Shows a real progress UI while Pyodide initializes
 * (2-5s cold start per published benchmarks). Then opens a small chat-like
 * surface where the agent walks through the VerdantForged protocol.
 *
 * Reference implementation: https://github.com/hdresearch/hermes-pyodide
 * We do NOT bundle the full Hermes runtime yet — for the hackathon demo we
 * load Pyodide + a minimal "verdantforged-explainer" script that reads AGENT.md
 * and summarizes the protocol. The full Hermes integration is post-hackathon.
 *
 * Pyodide CDN: https://cdn.jsdelivr.net/pyodide/v0.27.7/full/pyodide.js
 * Size: ~20 MB compressed. Loaded only on user click.
 */
---

<!-- Hidden splash container, becomes visible on click -->
<div
  id="browser-agent-splash"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/60 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="splash-title"
  aria-describedby="splash-status"
>
  <div class="bg-bg rounded-3xl shadow-2xl max-w-2xl w-full overflow-hidden">
    <!-- Header -->
    <header class="flex items-center justify-between px-8 py-5 border-b border-moss/30">
      <div class="flex items-center gap-3">
        <span class="w-2 h-2 rounded-full bg-copper animate-pulse-verdigris"></span>
        <h2 id="splash-title" class="font-display font-semibold text-ink">
          Loading Hermes Agent
        </h2>
      </div>
      <button
        type="button"
        id="splash-close"
        class="text-ink-soft hover:text-ink transition-colors p-1"
        aria-label="Close"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </header>

    <!-- Progress body -->
    <div id="splash-body" class="px-8 py-10">
      <!-- Stage 1: Pyodide runtime download -->
      <div class="space-y-6">
        <div>
          <div class="flex items-center justify-between text-caption font-mono uppercase tracking-widest text-ink-soft mb-2">
            <span>Python runtime (Pyodide / WASM)</span>
            <span id="stage-pyodide-status">pending</span>
          </div>
          <div class="h-1.5 bg-moss/30 rounded-full overflow-hidden">
            <div id="stage-pyodide-bar" class="h-full bg-copper transition-all duration-400 ease-apple" style="width: 0%"></div>
          </div>
          <p class="mt-2 text-caption text-ink-soft" id="stage-pyodide-detail">
            ≈ 20 MB · loaded only when you click
          </p>
        </div>

        <div>
          <div class="flex items-center justify-between text-caption font-mono uppercase tracking-widest text-ink-soft mb-2">
            <span>Hermes Agent runtime</span>
            <span id="stage-hermes-status">pending</span>
          </div>
          <div class="h-1.5 bg-moss/30 rounded-full overflow-hidden">
            <div id="stage-hermes-bar" class="h-full bg-copper transition-all duration-400 ease-apple" style="width: 0%"></div>
          </div>
          <p class="mt-2 text-caption text-ink-soft" id="stage-hermes-detail">
            Cutdown build for in-browser protocol walkthrough
          </p>
        </div>

        <div>
          <div class="flex items-center justify-between text-caption font-mono uppercase tracking-widest text-ink-soft mb-2">
            <span>VerdantForged skill</span>
            <span id="stage-skill-status">pending</span>
          </div>
          <div class="h-1.5 bg-moss/30 rounded-full overflow-hidden">
            <div id="stage-skill-bar" class="h-full bg-copper transition-all duration-400 ease-apple" style="width: 0%"></div>
          </div>
          <p class="mt-2 text-caption text-ink-soft" id="stage-skill-detail">
            Loads AGENT.md and prepares the protocol walkthrough
          </p>
        </div>
      </div>

      <!-- Live status line -->
      <p id="splash-status" class="mt-10 text-body-sm text-ink-soft font-mono" aria-live="polite">
        Ready when you are.
      </p>
    </div>

    <!-- Result body (hidden until done) -->
    <div id="splash-result" class="hidden px-8 py-10">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-2 h-2 rounded-full bg-verdigris-deep"></span>
        <span class="text-caption font-mono uppercase tracking-widest text-verdigris-deep">
          Hermes Agent ready
        </span>
      </div>

      <!-- Transcript (from Pyodide-loaded explainer) -->
      <details class="mb-6" open>
        <summary class="cursor-pointer text-caption font-mono uppercase tracking-widest text-ink-soft hover:text-copper transition-colors">
          ▾ What the agent just learned
        </summary>
        <div id="agent-output" class="mt-4 font-mono text-body-sm text-ink bg-moss/10 rounded-xl p-5 max-h-48 overflow-y-auto" aria-live="polite">
          <!-- Filled by the runtime once it boots -->
        </div>
      </details>

      <!-- Inline dashboard preview — the v2 centerpiece -->
      <div class="border-t border-moss/30 pt-6">
        <p class="vf-eyebrow text-verdigris-deep">Step into the dashboard</p>
        <p class="text-body text-ink mt-2">
          Open a sandbox. Watch the timer tick. See one escrow cover the broker, the skill, and the inference.
        </p>

        <!-- Compact dashboard tile -->
        <article
          id="vf-splash"
          class="mt-5 vf-card relative"
          data-session-active="false"
        >
          <!-- Idle state: shown until user clicks "Open sandbox" -->
          <div id="vf-splash-idle" class="flex flex-col items-center justify-center py-8 text-center">
            <code class="font-mono text-caption text-ink-soft uppercase tracking-widest">
              No active session
            </code>
            <p class="mt-3 text-body-sm text-ink-soft max-w-xs">
              Click below to provision a <code class="text-copper">python-3.11-base</code> enclave and watch the timer.
            </p>
            <button
              type="button"
              data-action="vf-splash-open-session"
              class="vf-button mt-6"
            >
              Open sandbox
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <!-- Active state: hidden until user opens a session -->
          <div id="vf-splash-active" class="hidden">
            <header class="flex items-start justify-between gap-4">
              <div class="flex flex-col gap-2">
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center gap-2 px-3 py-1 bg-verdigris-deep/10 border border-verdigris-deep/30 rounded-full text-caption font-mono text-verdigris-deep uppercase tracking-widest">
                    <span class="w-1.5 h-1.5 rounded-full bg-verdigris animate-pulse-verdigris"></span>
                    Active
                  </span>
                  <code class="text-caption text-ink-soft font-mono">sess_demo…</code>
                </div>
                <h3 class="text-body font-display font-semibold text-ink mt-1">
                  <code class="text-copper">python-3.11-base</code>
                  <span class="text-ink-soft font-normal text-caption ml-2">· attested SEV-SNP</span>
                </h3>
              </div>
              <span class="vf-eyebrow text-ink-soft">Session</span>
            </header>

            <!-- Countdown -->
            <div class="mt-6">
              <div class="flex items-baseline justify-between">
                <div>
                  <p class="vf-eyebrow text-ink-soft">Time remaining</p>
                  <p
                    class="mt-1 font-display font-semibold text-ink text-display-sm tabular-nums"
                    data-role="clock"
                  >
                    5:00
                  </p>
                </div>
                <div class="text-right">
                  <p class="vf-eyebrow text-ink-soft">Spent</p>
                  <p class="mt-1 font-mono text-body text-ink tabular-nums" data-role="total">
                    $0.0000
                  </p>
                </div>
              </div>
              <!-- Meter -->
              <div class="mt-3 h-1.5 bg-moss/20 rounded-full overflow-hidden">
                <div
                  class="h-full bg-copper transition-[width] duration-700"
                  style="width: 0%"
                  data-role="meter"
                ></div>
              </div>
            </div>

            <!-- Three affordances -->
            <div class="mt-6 grid grid-cols-3 gap-2">
              <button
                type="button"
                data-action="vf-splash-skill-call"
                class="vf-button justify-center text-caption"
              >
                Make skill call
              </button>
              <button
                type="button"
                data-action="vf-splash-extend"
                class="vf-button-ghost justify-center text-caption"
              >
                Extend
              </button>
              <button
                type="button"
                data-action="vf-splash-close"
                class="vf-button-ghost justify-center text-caption"
              >
                Close
              </button>
            </div>

            <!-- Compact call log -->
            <div
              class="mt-5 border-t border-moss/30 pt-4 space-y-2 text-caption font-mono"
              data-role="log"
            >
              <p class="text-ink-soft">No skill calls yet.</p>
            </div>
          </div>
        </article>
      </div>

      <p class="mt-6 text-caption text-ink-soft">
        This is a demonstration. Full Hermes Agent support in the browser is on the
        post-hackathon roadmap — see <a href={`${import.meta.env.BASE_URL}/AGENT.md`} class="vf-link">AGENT.md</a>
        for the production install path.
      </p>
    </div>

    <!-- Footer -->
    <footer class="px-8 py-5 border-t border-moss/30 bg-moss/5 flex items-center justify-between">
      <p class="text-caption text-ink-soft font-mono">
        Runs entirely in your browser · No data leaves your device
      </p>
      <p class="text-caption text-ink-soft font-mono">
        Powered by Pyodide
      </p>
    </footer>
  </div>
</div>

<script>
  import { createDashboard } from '~/lib/session-dashboard';
  import { loadVerdantAgent, type SkillResult } from '~/lib/verdant-agent';

  // BrowserAgentSplash — wires the "Try in browser" CTA to lazy-load Pyodide.
  // Reference implementation: https://github.com/hdresearch/hermes-pyodide
  //
  // This is a HACKATHON DEMO, not a full Hermes port. It:
  //   1. Loads Pyodide from CDN (~20MB, 2-5s on broadband)
  //   2. Bootstraps a minimal "verdantforged-explainer" Python module
  //   3. Fetches AGENT.md and summarizes it back to the user
  //
  // The full Hermes-pyodide integration is on the post-hackathon roadmap.

  const splash       = document.getElementById('browser-agent-splash');
  const closeBtn     = document.getElementById('splash-close');
  const statusLine   = document.getElementById('splash-status');
  const bodyEl       = document.getElementById('splash-body');
  const resultEl     = document.getElementById('splash-result');
  const outputEl     = document.getElementById('agent-output');
  const titleEl      = document.getElementById('splash-title');

  // Stage helpers
  type StageId = 'pyodide' | 'hermes' | 'skill';
  function setStage(stage: StageId, status: 'pending' | 'loading' | 'done' | 'error', percent: number, detail?: string) {
    const statusEl  = document.getElementById(`stage-${stage}-status`);
    const barEl     = document.getElementById(`stage-${stage}-bar`);
    const detailEl  = document.getElementById(`stage-${stage}-detail`);
    if (statusEl) statusEl.textContent = status;
    if (barEl)    barEl.style.width = `${percent}%`;
    if (detail && detailEl) detailEl.textContent = detail;
  }

  function setStatus(text: string) {
    if (statusLine) statusLine.textContent = text;
  }

  function showResult(html: string) {
    if (bodyEl)   bodyEl.classList.add('hidden');
    if (resultEl) resultEl.classList.remove('hidden');
    if (outputEl) outputEl.innerHTML = html;
    if (titleEl)  titleEl.textContent = 'VerdantForged, explained';
  }

  // Open / close
  function openSplash() {
    if (!splash) return;
    splash.classList.remove('hidden');
    splash.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeSplash() {
    if (!splash) return;
    splash.classList.add('hidden');
    splash.classList.remove('flex');
    document.body.style.overflow = '';
  }

  // ESC closes
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && splash && !splash.classList.contains('hidden')) closeSplash();
  });
  if (closeBtn) closeBtn.addEventListener('click', closeSplash);

  // Click backdrop closes
  if (splash) {
    splash.addEventListener('click', (e) => {
      if (e.target === splash) closeSplash();
    });
  }

  // Wire any element with [data-action="try-in-browser"] to open + boot
  document.querySelectorAll<HTMLElement>('[data-action="try-in-browser"]').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      openSplash();
      await bootInBrowserAgent();
    });
  });

  async function bootInBrowserAgent() {
    try {
      // ─── Stages 1-3: Pyodide + Hermes + Skill via the shared module ───
      // This populates window.__vfPyodide, window.__vfAgentSkill, and
      // registers verdantforged.explainer in Pyodide's sys.modules. The
      // landing-page SessionDashboard and the splash dashboard share
      // this singleton — calling loadVerdantAgent() is idempotent.
      setStage('pyodide', 'loading', 5, 'Downloading Python runtime (~20 MB)...');
      setStatus('Downloading Pyodide...');
      await new Promise((r) => setTimeout(r, 200));
      setStage('pyodide', 'loading', 30);

      // Start the load (will resolve when done). Show progress while we wait.
      const skillCall = await loadVerdantAgent();

      setStage('pyodide', 'done', 100, 'Python runtime ready');
      setStage('hermes', 'done', 100, 'Cutdown Hermes runtime ready');
      setStage('skill', 'loading', 50, 'Fetching AGENT.md...');
      await new Promise((r) => setTimeout(r, 200));
      setStage('skill', 'done', 100, 'Skill loaded');

      // ─── One-shot summary for the modal body ───────────────────────
      // The shared explainer cycles through sections; this first call
      // returns the first section's summary. The dashboard below will
      // call the same skill again on every "Make skill call" click.
      setStatus('Generating protocol summary...');
      const result = await skillCall();
      const summary = result.summary;

      setStatus('Ready.');
      // Render summary as HTML-safe markdown-ish blocks
      const html = summary
        .split(/§ (.+?) — /)
        .reduce<string[]>((acc, chunk, i) => {
          if (i === 0) return acc;
          if (i % 2 === 1) return [...acc, `<h3 class="text-display-sm font-display font-semibold text-copper-deep mt-4 mb-2">${chunk}</h3>`];
          return [...acc, `<p class="text-body text-ink-soft">${chunk.trim()}</p>`];
        }, [])
        .join('');
      showResult(html || '<p class="text-body text-ink-soft">Loaded. Ask me anything about VerdantForged.</p>');

    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      setStatus(`Error: ${msg}`);
      setStage('pyodide', 'error', 0, msg);
      console.error('[BrowserAgentSplash]', err);
    }
  }

  // ─── Inline dashboard wiring ──────────────────────────────────────────
  // Wires the compact dashboard tile in the result panel via the shared
  // session-dashboard module. The onSkillCall callback reuses the
  // Pyodide singleton loaded above (bootInBrowserAgent) — first call to
  // makeSkillCall resolves instantly because the skill is already loaded.
  createDashboard({
    rootId: 'vf-splash',
    maxBudgetUsd: 0.50,
    costPerMin: 0.0133,
    skillCostUsd: 0.0050,
    leaseSeconds: 300,    // 5-min demo
    extendSeconds: 120,   // +2 min per extend
    sessionShort: 'sess_demo',
    environment: 'python-3.11-base',
    onSkillCall: makeSplashSkillCall(),
  });

  // Late-bind the splash skill call. Waits for the shared Pyodide
  // singleton (loaded by the landing-page SessionDashboard's first
  // skill call OR by bootInBrowserAgent() above) before invoking.
  type SkillFn = () => Promise<SkillResult>;
  let _splashSkill: SkillFn | null = null;
  function makeSplashSkillCall(): () => Promise<SkillResult> {
    return async () => {
      if (!_splashSkill) {
        _splashSkill = await loadVerdantAgent();
      }
      return _splashSkill();
    };
  }
</script>
