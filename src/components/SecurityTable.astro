---
/**
 * SecurityTable — the 7-row guarantees table
 * Reads directly from the SPEC.md security model. Apple-style alternating row backgrounds.
 */

const rows = [
  { attack: 'Broker reads your skill source',            fix: 'Encrypted to enclave key; no debug interface' },
  { attack: 'Broker reads requester data',                fix: 'Encrypted to enclave key; same mechanism' },
  { attack: 'Broker copies your skill for later',         fix: 'Enclave is ephemeral; no persistent storage; measured boot' },
  { attack: 'Broker sends the result to someone else',    fix: 'Result encrypted to requester\'s pubkey; enclave has no other key' },
  { attack: 'Broker runs different code than you approved', fix: 'Attestation measurement = hash of approved binary' },
  { attack: 'Broker sends results anywhere except the requester', fix: 'OpenShell default-DENY policy; only api.stripe.com:443 allowed' },
  { attack: 'Broker stalls indefinitely',                 fix: 'Fuel limit (instruction count) + wall-clock timeout' },
];
---

<section id="security" class="vf-container section" aria-labelledby="security-heading">
  <p class="vf-eyebrow">What's actually enforced</p>
  <h2 id="security-heading" class="vf-heading-section mt-6 max-w-4xl">
    Trust the silicon, not the operator.
  </h2>
  <p class="vf-body-lead mt-8 max-w-2xl">
    Every guarantee below is enforced by the enclave or by Stripe MPP — not by
    policy, not by goodwill, not by the marketplace operator.
  </p>

  <div class="mt-16 max-w-5xl mx-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-moss">
          <th class="py-4 pr-6 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">
            Attack
          </th>
          <th class="py-4 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">
            What stops it
          </th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr class={`border-b border-moss/30 ${i % 2 === 1 ? 'bg-moss/5' : ''}`}>
            <td class="py-6 pr-6 text-body text-ink align-top vf-text-pretty">
              {row.attack}
            </td>
            <td class="py-6 text-body text-ink-soft align-top vf-text-pretty">
              {row.fix}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="vf-body-lead mt-16 max-w-2xl mx-auto text-center">
    VerdantForged is the marketplace. The guarantees are made by NVIDIA NemoClaw,
    Stripe MPP, and the protocol itself — not by us.
  </p>
</section>
