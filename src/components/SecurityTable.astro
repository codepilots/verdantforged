---
/**
 * SecurityTable — the deep-dive on the security pillar.
 *
 * The Pillars section above gives the 30-second view. This table is the
 * full attack/defense matrix, grounded in what the live broker actually
 * does (broker-daemon/daemon.py + worker/poller.py).
 *
 * Source-of-truth files:
 *   - broker-daemon/crypto.py, daemon.py (attestation, signature, sign)
 *   - worker/poller.py L48: FILE_ENCRYPTION = "x25519-hkdf-sha256-chacha20poly1305-v1"
 *   - worker/poller.py L47: INPUT_AAD = b"verdantforged-input"
 *   - broker-daemon/daemon.py validate_submit (L2091)
 *   - broker-daemon/daemon.py _verify_snp_quote_signature (L2200)
 *
 * Audience: a reviewer who wants the cryptographic primitives and the
 * specific protocol field names, not just the marketing version.
 */

const primitives = [
  {
    layer: 'Key exchange',
    algorithm: 'X25519 ECDH, ephemeral-static per envelope',
    why: 'A fresh ephemeral keypair per envelope gives forward secrecy; the worker static X25519 key is published in /v1/discover.attestation.enclave_pubkey so requesters encrypt without extra ceremony',
    test: 'tests/verify-crypto-e2e.py + tests/verify-ephemeral-static-ecdh.py — roundtrip, wrong-key fails, distinct ciphertexts per envelope',
  },
  {
    layer: 'KDF',
    algorithm: 'HKDF-SHA256, context-bound (verdantforged-input / verdantforged-result / verdantforged-artifact)',
    why: 'AAD-bound shared-secret derivation prevents a blob spliced from one channel (input vs artifact vs result) from decrypting in another',
    test: 'tests/verify-crypto-e2e.py — wrong-context fails, HKDF RFC 5869 vector',
  },
  {
    layer: 'AEAD',
    algorithm: 'ChaCha20-Poly1305 (IETF, 12-byte nonce, 16-byte tag)',
    why: 'Confidentiality + integrity in one primitive; wire format is ephemeral_pubkey || nonce || ciphertext||tag (60-byte overhead)',
    test: 'tests/verify-crypto-e2e.py — tamper detection on every byte position, nonce-uniqueness per envelope',
  },
  {
    layer: 'Worker identity',
    algorithm: 'Ed25519 (RFC 8032), persistent per host',
    why: 'Worker signs the result envelope; key persisted at /opt/worker/keys so two jobs from the same worker share a verifiable identity (VULN-S4: not derived from SEV-SNP — see _ensure_worker_signing_key)',
    test: 'tests/verify-security-fixes.py — roundtrip, tampered result rejected, missing signature rejected',
  },
  {
    layer: 'Broker non-repudiation',
    algorithm: 'Ed25519 (RFC 8032), per broker instance',
    why: 'Broker independently signs the canonical (result_hash|skill_hash|input_hash) tuple in _finalize_job. Workers do not learn the broker key; verifiers with the broker pubkey can prove the receipt passed through THIS broker',
    test: 'tests/verify-webhook-delivery.py + verify-stripe-integration.py — broker_signature present on completed, capture/refund flow proved end-to-end',
  },
  {
    layer: 'Attestation quote signature',
    algorithm: 'RSA-PSS via `_verify_snp_quote_signature()`',
    why: 'Verifies the 1184-byte SNP quote with its embedded VCEK/VLEK cert against the supplied cert_chain. Clients re-verify against the AMD root before trusting the measurement',
    test: 'tests/verify-attestation-audit.py + verify-sev-snp-framework.py — 1184-byte length check, cert chain presence, rsa-pss accepts good / rejects tampered',
  },
  {
    layer: 'Hash',
    algorithm: 'SHA-256 / SHA-384 (measurement), sha256(skill_hash) for WASM dispatch',
    why: 'NIST standard; crypto.hash_field() recomputes sha256(encrypted_skill) at submit time so the broker can bind the envelope hash',
    test: 'tests/verify-crypto-e2e.py — known "abc" vector for SHA-256, RFC test vector for HKDF',
  },
];

const requestValidation = [
  { check: 'encrypted_skill present',         detail: 'Rejects empty payload (replay/sanity)' },
  { check: 'encrypted_data present',          detail: 'Rejects empty payload (replay/sanity)' },
  { check: 'requester_sig present',           detail: 'Ed25519 signature over the canonical envelope; optional pubkey for opt-in verification' },
  { check: 'result_pubkey well-formed',       detail: '32-byte base64 X25519 pubkey; file jobs require it (code: file_encryption_required)' },
  { check: 'stripe_pi_id format-valid',      detail: 'Pattern pi_<base62> (Stripe PaymentIntent ID format)' },
  { check: 'encrypt_input capability check',  detail: 'Registered skills with decrypt_input=true are honored; unknown skills never get the decrypt path' },
  { check: 'wasm_uri optional',              detail: 'If set, broker resolves + verifies skill_hash from the registered skills table before injecting' },
  { check: 'Input files (optional)',         detail: 'Filename allowlist, ≤50 MB per file, ≤10 files, requires valid X25519 result_pubkey' },
];

const attestationChecks = [
  { check: 'Non-empty SNP report (1184 bytes)',  detail: 'verify-attestation-audit.py — empty_attestation_fails' },
  { check: 'Cert chain present + well-formed',    detail: 'verify-attestation-audit.py — invalid_cert_chain_fails' },
  { check: 'RSA-PSS signature verifies',          detail: 'verify-attestation-audit.py + verify-sev-snp-framework.py — tampered_signature_rejected, quote_signature_roundtrip' },
  { check: 'Measurement matches expected',       detail: 'Loaded into worker.attestation; advertised in /v1/discover for client-side compare' },
  { check: 'report_data bound to worker key',     detail: '_load_verified_worker_identity — HMAC(binding) === sha256(worker_keys.x25519_pubkey) embedded in report_data' },
  { check: 'Worker Ed25519 attestation key',      detail: 'Persistent per host (VULN-S4); per-job eph_x25519 used for the input channel' },
];
---

<section
  id="security"
  class="vf-container section"
  aria-labelledby="security-heading"
>
  <p class="vf-eyebrow">Security · deep dive</p>
  <h2 id="security-heading" class="vf-heading-section mt-6 max-w-4xl">
    Every primitive is named. Every test is named.
  </h2>
  <p class="vf-body-lead mt-8 max-w-2xl">
    The pillars section gives the 30-second pitch. This is the receipt: the
    crypto stack, the input validation, the attestation checks — and the
    specific test name that proves each one. The full source of truth is
    <a
      href="/docs"
      class="vf-link"
    >/docs</a> on the live broker and the
    <a
      href="/security/"
      class="vf-link"
    >/security</a> deep dive.
  </p>

  <!-- Cryptographic primitives -->
  <div class="mt-20 max-w-5xl">
    <h3 class="text-display-sm font-display font-semibold text-ink">
      Cryptographic primitives
    </h3>
    <div class="mt-8 overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-moss">
            <th class="py-4 pr-6 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">Layer</th>
            <th class="py-4 pr-6 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">Algorithm</th>
            <th class="py-4 pr-6 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">Why</th>
            <th class="py-4 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">Test</th>
          </tr>
        </thead>
        <tbody>
          {primitives.map((row, i) => (
            <tr class={`border-b border-moss/30 align-top ${i % 2 === 1 ? 'bg-moss/5' : ''}`}>
              <td class="py-5 pr-6 text-body-sm text-ink font-mono whitespace-nowrap">{row.layer}</td>
              <td class="py-5 pr-6 text-body-sm text-copper-deep font-mono whitespace-nowrap">{row.algorithm}</td>
              <td class="py-5 pr-6 text-body-sm text-ink-soft vf-text-pretty">{row.why}</td>
              <td class="py-5 text-caption text-ink-soft font-mono vf-text-pretty">{row.test}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ExecutionRequest validation -->
  <div class="mt-24 max-w-5xl">
    <h3 class="text-display-sm font-display font-semibold text-ink">
      ExecutionRequest validation
    </h3>
    <p class="mt-4 text-body text-ink-soft max-w-prose-vf">
      Every incoming request is checked against these constraints before the
      enclave boots. Rejecting a request here is cheap; rejecting it after the
      enclave is up wastes a sandbox.
    </p>
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-3 max-w-4xl">
      {requestValidation.map((row) => (
        <div class="flex gap-3">
          <span class="text-verdigris-deep shrink-0 mt-1" aria-hidden="true">✓</span>
          <div>
            <code class="text-body-sm text-ink font-mono">{row.check}</code>
            <p class="text-caption text-ink-soft mt-1">{row.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Attestation checks -->
  <div class="mt-24 max-w-5xl">
    <h3 class="text-display-sm font-display font-semibold text-ink">
      Attestation verification
    </h3>
    <p class="mt-4 text-body text-ink-soft max-w-prose-vf">
      Six checks run on every attestation report before the requester
      hands over the encrypted payload. Any one failing aborts the session.
    </p>
    <div class="mt-8 overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-moss">
            <th class="py-4 pr-6 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">Check</th>
            <th class="py-4 text-caption font-mono uppercase tracking-widest text-ink-soft font-medium">Test name</th>
          </tr>
        </thead>
        <tbody>
          {attestationChecks.map((row, i) => (
            <tr class={`border-b border-moss/30 align-top ${i % 2 === 1 ? 'bg-moss/5' : ''}`}>
              <td class="py-4 pr-6 text-body-sm text-ink">{row.check}</td>
              <td class="py-4 text-body-sm text-copper-deep font-mono">{row.detail}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Footer -->
  <div class="mt-20 max-w-2xl mx-auto text-center">
    <p class="vf-body-lead">
      The full live-broker test suite runs against the broker at
      <code class="font-mono text-copper-deep">verdant.codepilots.co.uk</code>
      — 30+ verify-*.py scripts under
      <code class="font-mono text-copper-deep">tee-broker-deploy/tests/</code>
      covering crypto, attestation, dispatch, WASM, payment, and webhook delivery.
    </p>
    <p class="mt-6 text-caption text-ink-soft font-mono">
      The crypto, the broker, the worker, and the test suite are real.
      Simulated: only the WASM binaries shipped in
      <code class="font-mono text-copper-deep">skill_library/</code>
      that have no on-disk binary yet. Real binaries are uploaded via
      <code class="font-mono text-copper-deep">/v1/skills</code> and execute against the live broker.
    </p>
  </div>
</section>
