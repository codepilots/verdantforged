---
/**
 * /agent — Hermes Portable full-page runner (v3)
 *
 * The page is a full takeover (no parent chrome, no fixed overlay) so:
 *   - No clipping on narrow viewports
 *   - Native page scroll on the chat history when entries exceed viewport
 *   - Browser handles history (back button returns to home)
 *   - No layout interaction with the parent page's sticky elements
 *
 * Hermes Portable boots itself — no button press. WebLLM warms on first
 * user activity, Pyodide warms on chat-input focus. The broker session
 * is opened by the agent itself when it decides a real skill is needed.
 *
 * The actual layout lives in AgentRunner.astro (banner → chat → input).
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import AgentRunner from '~/components/AgentRunner.astro';
---

<BaseLayout
  title="VerdantForged · Hermes Portable"
  description="Hermes Portable running in your browser. Real inference via WebLLM, real skills via Pyodide, broker sessions opened by the agent on demand."
>
  <AgentRunner />
</BaseLayout>
