---
/**
 * agent.astro — VerdantForged dumb-client demo page
 *
 * Layout:
 *
 *   ┌─ HEADER (sticky) ────────────────────────────────────────────┐
 *   │  VerdantForged · Demo                          ← back       │
 *   │  broker connection · session id · cost ticker · status pill │
 *   └──────────────────────────────────────────────────────────────┘
 *
 *   ┌─ LEFT (1/3): DUMB CHAT ─────┐  ┌─ RIGHT (2/3): SPONSOR PANES ─┐
 *   │                             │  │  ┌──────┬──────┬──────┐      │
 *   │  you: review this Python    │  │  │NVIDIA│ Nous │Stripe│      │
 *   │                             │  │  └──────┴──────┴──────┘      │
 *   │  broker: plan ready         │  │                              │
 *   │  (modal opens → see right)  │  │  [three panels, live updates]│
 *   │                             │  │                              │
 *   │  ┌─ MODAL (overlay) ──────┐ │  │                              │
 *   │  │ ⬢ plan with cost       │ │  │                              │
 *   │  │ ⬢ attestation summary  │ │  │                              │
 *   │  │ ⬢ approve/reject/modify│ │  │                              │
 *   │  └────────────────────────┘ │  │                              │
 *   │                             │  │                              │
 *   │  [textarea: ask anything]   │  │                              │
 *   │  [send]                     │  │                              │
 *   └─────────────────────────────┘  └──────────────────────────────┘
 *
 * The dumb client runs NO LLM. It just POSTs free-text to the broker
 * and shows whatever comes back. This proves the marketplace is usable
 * by any agent — including curl scripts, tiny models, and voice
 * assistants. The three panels make the work happening server-side
 * tangible: NVIDIA's attestation, Nous's planner reasoning, Stripe's
 * money trail.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import SponsorPanel from '~/components/SponsorPanel.astro';
---

<BaseLayout
  title="VerdantForged — Demo · A dumb client. A smart broker."
  description="Type anything. Watch NVIDIA attest the enclave, Nous plan the work, and Stripe settle per step. Real protocol, mock execution, no LLM in your browser."
  ogImage="/og.png"
>
  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <header
    id="vf-banner"
    class="sticky top-0 z-30 bg-bg/95 backdrop-blur-sm border-b border-moss/30"
    aria-label="Broker session banner"
  >
    <div class="vf-container flex flex-wrap items-center gap-x-6 gap-y-2 py-3">
      <div class="flex items-center gap-3">
        <a href={`${import.meta.env.BASE_URL}/`} class="vf-eyebrow text-ink-soft hover:text-copper transition-colors">
          ← verdantforged
        </a>
        <span class="text-moss">·</span>
        <span class="vf-eyebrow text-ink">demo</span>
      </div>

      <div class="flex items-center gap-2">
        <span
          id="vf-banner-pulse"
          class="w-2 h-2 rounded-full bg-verdigris-deep"
          aria-hidden="true"
        ></span>
        <code
          id="vf-banner-status"
          class="font-mono text-caption uppercase tracking-widest text-ink-soft"
          data-role="banner-status"
        >broker ready · mock</code>
      </div>

      <div class="flex items-center gap-2">
        <span class="vf-eyebrow text-ink-soft">session</span>
        <code id="vf-banner-session" class="font-mono text-caption text-ink-soft">none</code>
      </div>

      <div class="flex items-baseline gap-2">
        <span class="vf-eyebrow text-ink-soft">spent</span>
        <code id="vf-banner-cost" class="font-mono text-body text-copper-deep tabular-nums">$0.0000</code>
      </div>

      <div class="flex items-baseline gap-2">
        <span class="vf-eyebrow text-ink-soft">calls</span>
        <code id="vf-banner-calls" class="font-mono text-body text-ink tabular-nums">0</code>
      </div>

      <div class="ml-auto vf-eyebrow text-ink-soft hidden md:block">
        dumb client · no LLM in your browser
      </div>
    </div>
  </header>

  <main class="vf-container py-8">
    <!-- ── TWO-COLUMN LAYOUT ────────────────────────────────────── -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- ── LEFT: DUMB CHAT (1/3) ───────────────────────────────── -->
      <section
        class="lg:col-span-1 flex flex-col gap-4"
        aria-label="Dumb client chat"
      >
        <header>
          <p class="vf-eyebrow text-verdigris-deep">dumb client</p>
          <h1 class="font-display font-semibold text-ink text-display-sm leading-tight mt-2">
            Type anything.
          </h1>
          <p class="text-body-sm text-ink-soft mt-3">
            No model runs in your browser. The broker does the planning, attestation,
            and settlement. If this dumb client can drive the marketplace, any agent can.
          </p>
        </header>

        <!-- Chat stream -->
        <div
          id="vf-chat-stream"
          data-role="chat-stream"
          class="flex-1 min-h-[280px] max-h-[50vh] overflow-y-auto rounded-2xl border border-moss/30 bg-moss/5 p-5 space-y-4"
          role="log"
          aria-live="polite"
        >
          <div class="text-ink-soft text-body-sm font-mono">
            <p>ready. type to begin.</p>
            <p class="mt-2 text-caption">try: "review this Python file", "compute fib(40)", "translate to french", "summarize the docs"</p>
          </div>
        </div>

        <!-- Textarea + send -->
        <form
          id="vf-prompt-form"
          class="flex flex-col gap-3"
          aria-label="Send a free-text intent to the broker"
        >
          <label for="vf-prompt-input" class="sr-only">Your intent (free text)</label>
          <textarea
            id="vf-prompt-input"
            data-role="prompt-input"
            placeholder="ask the broker anything..."
            rows="2"
            autocomplete="off"
            spellcheck="true"
            class="w-full bg-bg border border-moss rounded-2xl px-4 py-3 font-sans text-body text-ink placeholder:text-ink-soft focus:border-copper focus:outline-none transition-colors resize-none"
          ></textarea>
          <div class="flex items-center justify-between gap-3">
            <p class="text-caption text-ink-soft font-mono">
              broker.intent(text) → plan → you approve
            </p>
            <button
              type="submit"
              class="vf-button"
              data-role="send-button"
            >
              Send intent
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </form>
      </section>

      <!-- ── RIGHT: THREE SPONSOR PANELS (2/3) ───────────────────── -->
      <section
        class="lg:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-4"
        aria-label="Sponsor panels (NVIDIA, Nous, Stripe)"
        data-role="sponsor-grid"
      >
        <SponsorPanel
          sponsor="nvidia"
          name="NemoClaw"
          role="SEV-SNP attestation · OpenShell egress"
        />
        <SponsorPanel
          sponsor="nous"
          name="Hermes"
          role="planner LLM · skill runtime"
        />
        <SponsorPanel
          sponsor="stripe"
          name="MPP"
          role="PaymentIntent · per-step Transfer · refund"
        />
      </section>
    </div>

    <!-- ── ARCHITECTURE DIAGRAM ─────────────────────────────────── -->
    <section class="mt-12 max-w-5xl mx-auto" aria-label="How the demo works">
      <details class="vf-card group">
        <summary class="cursor-pointer flex items-center justify-between py-4 px-6">
          <div>
            <p class="vf-eyebrow text-verdigris-deep">architecture</p>
            <p class="font-display font-semibold text-ink text-body-lg mt-1">How this demo works</p>
          </div>
          <span class="text-caption font-mono text-ink-soft group-open:rotate-90 transition-transform">▸</span>
        </summary>
        <div class="px-6 pb-6">
          <img
            src={`${import.meta.env.BASE_URL}/diagrams/data-flow.png`}
            alt="Data flow diagram: dumb client sends intent to broker, broker fans out to NVIDIA NemoClaw (attestation), Nous Hermes (planning), and Stripe MPP (payment) panels"
            class="w-full rounded-xl border border-moss/30"
            loading="lazy"
          />
          <p class="text-caption text-ink-soft font-mono mt-3">
            The dumb client runs zero LLM. It POSTs free text to the broker, which plans the work,
            attests the enclave, and settles per step — each sponsor panel updates live.
          </p>
        </div>
      </details>
    </section>

    <!-- ── RECEIPTS / MONEY TRAIL (appears after execution) ─────── -->
    <section
      id="vf-receipts"
      class="mt-8 hidden"
      data-role="receipts-section"
      aria-label="Per-step receipts"
    >
      <header class="mb-4">
        <p class="vf-eyebrow text-copper-deep">money trail</p>
        <h2 class="font-display font-semibold text-ink text-display-sm leading-tight mt-2">
          per-step receipts
        </h2>
        <p class="text-body-sm text-ink-soft mt-2" data-role="receipts-summary">
          —
        </p>
      </header>
      <div
        id="vf-receipts-list"
        data-role="receipts-list"
        class="space-y-3"
      >
        <!-- Receipts rendered here by JS as transfers fire -->
      </div>
    </section>

    <!-- ── "STANDS ON" CREDITS ──────────────────────────────────── -->
    <footer class="mt-16 pt-8 border-t border-moss/30 text-caption text-ink-soft font-mono">
      <p class="vf-eyebrow mb-3">stands on</p>
      <ul class="space-y-1">
        <li>● NVIDIA NemoClaw — SEV-SNP attestation + OpenShell egress</li>
        <li>● Stripe Connect — per-step Transfers with application_fee</li>
        <li>● Nous Hermes — planner LLM (Hermes-3-8B) inside the enclave</li>
        <li>● Mock broker — see <a href="https://gitlab.com/autumn/broker" class="underline hover:text-copper">tee-broker-docs/site/BROKER_RPC.md</a></li>
      </ul>
    </footer>
  </main>

  <!-- ── HUMAN-GATE MODAL (hidden by default) ─────────────────── -->
  <div
    id="vf-modal-overlay"
    class="fixed inset-0 z-50 bg-bark/60 backdrop-blur-sm hidden items-center justify-center p-4"
    data-role="modal-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby="vf-modal-title"
  >
    <div class="bg-bg rounded-2xl border border-moss max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
      <header class="sticky top-0 bg-bg border-b border-moss/30 px-6 py-4 flex items-center justify-between">
        <div>
          <p class="vf-eyebrow text-copper-deep">broker proposes a plan</p>
          <h2 id="vf-modal-title" class="font-display font-semibold text-ink text-body-lg mt-1">
            review &amp; approve
          </h2>
        </div>
        <button
          type="button"
          class="vf-button-ghost text-caption"
          data-role="modal-close"
          aria-label="Reject and close"
        >✕</button>
      </header>

      <div class="px-6 py-5 space-y-5">
        <!-- Enclave attestation summary -->
        <div class="rounded-xl border border-[#76b900]/40 bg-[#76b900]/5 p-4">
          <p class="vf-eyebrow text-[#76b900] mb-2">attested by nvidia</p>
          <p class="text-caption font-mono text-ink-soft">
            <span data-role="attest-measurement">—</span>
          </p>
          <p class="text-caption font-mono text-ink-soft mt-1">
            policy: <span data-role="attest-policy">—</span>
          </p>
        </div>

        <!-- Plan steps -->
        <div>
          <p class="vf-eyebrow text-ink mb-2">plan</p>
          <ol class="space-y-3" data-role="plan-steps">
            <!-- plan steps rendered here by JS -->
          </ol>
        </div>

        <!-- Totals -->
        <div class="flex items-baseline justify-between border-t border-moss/30 pt-4">
          <span class="vf-eyebrow text-ink">total estimate</span>
          <span class="font-mono text-display-sm font-semibold text-copper-deep tabular-nums" data-role="modal-total">
            —
          </span>
        </div>

        <!-- Modify box (hidden by default) -->
        <div class="hidden" data-role="modify-box">
          <label for="vf-modify-input" class="vf-eyebrow text-ink block mb-2">
            what should change?
          </label>
          <textarea
            id="vf-modify-input"
            rows="2"
            placeholder="e.g. skip step 2, add a sql-query step, only run if file is small"
            class="w-full bg-bg border border-moss rounded-xl px-3 py-2 font-sans text-body-sm text-ink placeholder:text-ink-soft focus:border-copper focus:outline-none transition-colors resize-none"
          ></textarea>
          <div class="mt-2 flex gap-2 justify-end">
            <button type="button" class="vf-button-ghost text-caption" data-role="modify-cancel">cancel</button>
            <button type="button" class="vf-button text-caption" data-role="modify-submit">resubmit</button>
          </div>
        </div>

        <!-- Three buttons -->
        <div class="flex flex-wrap gap-3 justify-end pt-2" data-role="modal-buttons">
          <button type="button" class="vf-button-ghost" data-role="modal-reject">
            reject
          </button>
          <button type="button" class="vf-button-ghost" data-role="modal-modify">
            modify
          </button>
          <button type="button" class="vf-button" data-role="modal-approve">
            approve &amp; pay
          </button>
        </div>

        <p class="text-caption text-ink-soft font-mono pt-2">
          approve creates a Stripe PaymentIntent in test mode. you won't be charged.
        </p>
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  /**
   * /agent/ page script — the dumb client.
   *
   *  - import the mock broker (or real client tomorrow)
   *  - listen for broker events and update the three panels
   *  - handle approve / reject / modify
   *  - talk to Stripe.js v3 for real PaymentIntent creation in test mode
   *  - render per-step receipts as transfers fire
   */

  import { broker } from '~/lib/broker-mock';
  import type {
    PlanResponse,
    ExecutionTrace,
    BrokerEvent,
    IntentRequest,
    ApprovalRequest,
    ModificationRequest,
  } from '~/lib/broker-types';

  // ── Element handles ──────────────────────────────────────────
  const banner        = document.getElementById('vf-banner');
  const bannerPulse   = document.getElementById('vf-banner-pulse');
  const bannerStatus  = document.getElementById('vf-banner-status');
  const bannerSession = document.getElementById('vf-banner-session');
  const bannerCost    = document.getElementById('vf-banner-cost');
  const bannerCalls   = document.getElementById('vf-banner-calls');
  const chatStream    = document.getElementById('vf-chat-stream');
  const promptForm    = document.getElementById('vf-prompt-form') as HTMLFormElement | null;
  const promptInput   = document.getElementById('vf-prompt-input') as HTMLTextAreaElement | null;

  const modalOverlay    = document.getElementById('vf-modal-overlay');
  const planStepsEl     = document.querySelector<HTMLElement>('[data-role="plan-steps"]');
  const modalTotalEl    = document.querySelector<HTMLElement>('[data-role="modal-total"]');
  const attestMeasEl    = document.querySelector<HTMLElement>('[data-role="attest-measurement"]');
  const attestPolEl     = document.querySelector<HTMLElement>('[data-role="attest-policy"]');
  const modifyBox       = document.querySelector<HTMLElement>('[data-role="modify-box"]');
  const modifyInput     = document.getElementById('vf-modify-input') as HTMLTextAreaElement | null;
  const receiptsSection = document.getElementById('vf-receipts');
  const receiptsList    = document.getElementById('vf-receipts-list');
  const receiptsSummary = document.querySelector<HTMLElement>('[data-role="receipts-summary"]');

  // ── Session state ────────────────────────────────────────────
  let currentPlan: PlanResponse | null = null;
  let totalSpent = 0;
  let callCount = 0;

  function fmtMoney(n: number): string {
    return `$${n.toFixed(4)}`;
  }

  function appendChat(role: 'you' | 'broker' | 'plan' | 'system', text: string, extra?: Record<string, string>): void {
    if (!chatStream) return;
    const bubble = document.createElement('div');
    bubble.className = 'text-body-sm font-mono leading-relaxed';
    const author = role === 'you' ? 'you'
      : role === 'broker' ? 'dumb-client'
      : role === 'plan' ? 'broker:plan'
      : 'system';
    const colorClass = role === 'you' ? 'text-copper-deep'
      : role === 'broker' ? 'text-verdigris-deep'
      : role === 'plan' ? 'text-ink'
      : 'text-ink-soft';
    bubble.innerHTML = `<span class="${colorClass} font-semibold">${author}</span> · ${escapeHtml(text)}`;
    if (extra) {
      for (const [k, v] of Object.entries(extra)) {
        const span = document.createElement('span');
        span.className = 'ml-3 text-ink-50';
        span.textContent = `${k}: ${v}`;
        bubble.appendChild(span);
      }
    }
    chatStream.appendChild(bubble);
    chatStream.scrollTop = chatStream.scrollHeight;
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // ── Sponsor panel updaters ───────────────────────────────────
  function setPanelStatus(sponsor: 'nvidia' | 'nous' | 'stripe', status: 'idle' | 'active' | 'done' | 'error', label: string): void {
    const panel = document.querySelector<HTMLElement>(`[data-sponsor="${sponsor}"]`);
    if (panel) panel.dataset.status = status;
    const statusEl = document.querySelector<HTMLElement>(`[data-role="${sponsor}-status"]`);
    if (statusEl) statusEl.textContent = label;
  }

  function setPanelBody(sponsor: 'nvidia' | 'nous' | 'stripe', html: string): void {
    const body = document.querySelector<HTMLElement>(`[data-role="${sponsor}-body"]`);
    if (body) body.innerHTML = html;
  }

  function clearPanels(): void {
    setPanelStatus('nvidia', 'idle', 'awaiting plan');
    setPanelStatus('nous', 'idle', 'awaiting plan');
    setPanelStatus('stripe', 'idle', 'awaiting plan');
    setPanelBody('nvidia', '<p class="text-ink-soft"><span class="text-ink-50">waiting for plan...</span></p>');
    setPanelBody('nous', '<p class="text-ink-soft"><span class="text-ink-50">waiting for plan...</span></p>');
    setPanelBody('stripe', '<p class="text-ink-soft"><span class="text-ink-50">waiting for plan...</span></p>');
    if (receiptsSection) receiptsSection.classList.add('hidden');
    if (receiptsList)    receiptsList.innerHTML = '';
  }

  // ── Stripe client (test mode, optional) ──────────────────────
  // We try to load Stripe.js from CDN; if it fails (or no key), we run
  // in "mock stripe" mode and synthesize PaymentIntent IDs. The page
  // works either way — judges see the protocol either way.

  let stripeInstance: any = null;
  let stripeInMockMode = true;

  async function initStripe(): Promise<void> {
    const pk = (import.meta as any).env?.PUBLIC_STRIPE_PK;
    if (!pk) {
      console.info('[stripe] no PUBLIC_STRIPE_PK — running in mock stripe mode');
      stripeInMockMode = true;
      return;
    }
    try {
      // Load Stripe.js from CDN (only on this page, not globally)
      if (!(window as any).Stripe) {
        await new Promise<void>((resolve, reject) => {
          const s = document.createElement('script');
          s.src = 'https://js.stripe.com/v3/';
          s.onload = () => resolve();
          s.onerror = () => reject(new Error('failed to load stripe.js'));
          document.head.appendChild(s);
        });
      }
      stripeInstance = (window as any).Stripe(pk);
      stripeInMockMode = false;
      console.info('[stripe] loaded real Stripe.js — paymentIntents.create will fire against test API');
    } catch (err) {
      console.warn('[stripe] load failed, falling back to mock:', err);
      stripeInMockMode = true;
    }
  }

  async function createPaymentIntent(amountCents: number, label: string): Promise<string> {
    if (stripeInMockMode || !stripeInstance) {
      // Mock PI ID — same shape as Stripe's `pi_test_...`
      const rand = Math.random().toString(36).slice(2, 26);
      return `pi_test_${rand}`;
    }
    try {
      const result = await stripeInstance.paymentIntents.create({
        amount: amountCents,
        currency: 'usd',
        payment_method_types: ['card'],
        confirm: false, // demo: don't actually confirm (would need a payment method)
        description: label,
      });
      return result.id;
    } catch (err) {
      console.warn('[stripe] create failed, falling back to mock ID:', err);
      return `pi_test_${Math.random().toString(36).slice(2, 26)}`;
    }
  }

  // ── Subscribe to broker events ───────────────────────────────
  broker.subscribe((e: BrokerEvent) => {
    switch (e.type) {
      case 'session:opened':
        if (bannerSession) bannerSession.textContent = e.session_id;
        setPanelStatus('nvidia', 'active', 'attesting enclave');
        setPanelStatus('nous', 'active', 'planning');
        setPanelStatus('stripe', 'active', 'awaiting approval');
        break;

      case 'enclave:attested':
        setPanelStatus('nvidia', 'active', 'attested · ready');
        setPanelBody('nvidia', `
          <p class="text-ink-soft"><span class="text-ink-50">SEV-SNP report:</span></p>
          <p class="text-caption break-all"><span class="text-ink-50">measurement</span> ${escapeHtml(e.measurement.slice(0, 32))}…</p>
          <p class="text-caption"><span class="text-ink-50">openshell</span> ${escapeHtml(e.openshell_policy)}</p>
          <p class="text-caption text-verdigris-deep">✓ attested by AMD root CA</p>
        `);
        break;

      case 'planner:reasoning':
        appendPanelLine('nous', e.content, 'reasoning');
        break;

      case 'step:started':
        setPanelStatus('nous', 'active', `step ${e.step} · running`);
        setPanelBody('nous', `
          <p class="text-ink-soft"><span class="text-ink-50">planner · Hermes-3-8B</span></p>
          <p class="text-caption"><span class="text-ink-50">step ${e.step}</span> ${escapeHtml(e.skill)}</p>
          <p class="text-caption"><span class="text-ink-50">env</span> ${escapeHtml(e.skill)}</p>
          <p class="text-caption"><span class="text-ink-50">fuel budget</span> ${e.fuel_budget.toLocaleString()}</p>
        `);
        setPanelBody('nvidia', `
          <p class="text-ink-soft"><span class="text-ink-50">wasmtime · step ${e.step}</span></p>
          <p class="text-caption"><span class="text-ink-50">fuel</span> <span data-role="nvidia-fuel">0</span> / ${e.fuel_budget.toLocaleString()}</p>
          <p class="text-caption"><span class="text-ink-50">openshell</span> api.stripe.com:443 only</p>
          <div class="w-full h-1.5 bg-moss/30 rounded-full overflow-hidden">
            <div class="h-full bg-[#76b900] transition-all duration-300" data-role="nvidia-fuel-bar" style="width: 0%"></div>
          </div>
        `);
        break;

      case 'fuel:tick':
        updateFuelBar(e.step, e.fuel_used, e.fuel_budget);
        break;

      case 'transfer:created':
        callCount += 1;
        totalSpent += e.amount_usd;
        if (bannerCalls) bannerCalls.textContent = String(callCount);
        if (bannerCost)  bannerCost.textContent  = fmtMoney(totalSpent);
        appendReceipt(e.step, e.transfer_id, e.destination_acct, e.destination_name, e.amount_usd, e.application_fee_usd);
        break;

      case 'step:completed':
        appendPanelLine('nous', `step ${e.step} result: ${e.result_summary}`, 'done');
        setPanelStatus('nvidia', 'active', `step ${e.step} done`);
        break;

      case 'session:closed':
        setPanelStatus('nvidia', 'done', 'enclave burned');
        setPanelStatus('nous', 'done', 'plan executed');
        setPanelStatus('stripe', 'done', 'settled');
        // Update Stripe panel body with totals + refund id
        const refundLine = e.refund_id
          ? `<p class="text-caption text-verdigris-deep">refund ${escapeHtml(e.refund_id)}</p>`
          : `<p class="text-caption text-ink-soft">no refund needed (estimate = actual)</p>`;
        setPanelBody('stripe', `
          <p class="text-ink-soft"><span class="text-ink-50">settled</span></p>
          <p class="text-caption"><span class="text-ink-50">actual</span> ${fmtMoney(e.totals.actual_cost_usd)}</p>
          <p class="text-caption"><span class="text-ink-50">broker app_fee</span> ${fmtMoney(e.totals.broker_retained_usd)}</p>
          <p class="text-caption"><span class="text-ink-50">providers paid</span> ${fmtMoney(e.totals.skill_provider_paid_usd)}</p>
          ${refundLine}
        `);
        if (receiptsSection) receiptsSection.classList.remove('hidden');
        if (receiptsSummary) {
          const t = e.totals;
          receiptsSummary.textContent =
            `actual ${fmtMoney(t.actual_cost_usd)} · ` +
            `estimated ${fmtMoney(t.estimated_cost_usd)} · ` +
            `refund ${fmtMoney(t.refund_usd)} · ` +
            `broker app_fee ${fmtMoney(t.stripe_application_fee_usd)}` +
            (e.refund_id ? ` · refund id ${e.refund_id}` : '');
        }
        if (bannerStatus) bannerStatus.textContent = 'session closed';
        break;
    }
  });

  function appendPanelLine(sponsor: 'nvidia' | 'nous' | 'stripe', text: string, kind: 'reasoning' | 'done'): void {
    const body = document.querySelector<HTMLElement>(`[data-role="${sponsor}-body"]`);
    if (!body) return;
    const line = document.createElement('p');
    line.className = `text-caption ${kind === 'done' ? 'text-verdigris-deep' : 'text-ink'}`;
    line.textContent = `> ${text}`;
    body.appendChild(line);
  }

  function updateFuelBar(step: number, fuel: number, budget: number): void {
    const el = document.querySelector<HTMLElement>('[data-role="nvidia-fuel"]');
    if (el) el.textContent = fuel.toLocaleString();
    const bar = document.querySelector<HTMLElement>('[data-role="nvidia-fuel-bar"]');
    if (bar) bar.style.width = `${Math.min(100, (fuel / budget) * 100).toFixed(1)}%`;
  }

  function appendReceipt(step: number, transferId: string, destAcct: string, destName: string, amount: number, appFee: number): void {
    if (!receiptsList) return;
    const row = document.createElement('div');
    row.className = 'rounded-xl border border-moss/30 bg-bg p-4 font-mono text-caption';
    row.dataset.step = String(step);
    row.innerHTML = `
      <div class="flex items-baseline justify-between gap-3 mb-2">
        <span class="text-ink">step ${step} · ${escapeHtml(destName)}</span>
        <span class="text-copper-deep text-body font-semibold tabular-nums">${fmtMoney(amount)}</span>
      </div>
      <p class="text-ink-soft break-all"><span class="text-ink-50">transfer</span> ${escapeHtml(transferId)}</p>
      <p class="text-ink-soft"><span class="text-ink-50">to acct</span> ${escapeHtml(destAcct)}</p>
      <p class="text-ink-soft"><span class="text-ink-50">app_fee</span> ${fmtMoney(appFee)} (5%)</p>
    `;
    receiptsList.appendChild(row);
  }

  // ── Modal: show / hide / buttons ─────────────────────────────
  function showModal(plan: PlanResponse): void {
    currentPlan = plan;
    if (!modalOverlay) return;
    modalOverlay.classList.remove('hidden');
    modalOverlay.classList.add('flex');

    if (attestMeasEl) attestMeasEl.textContent = `measurement ${plan.enclave_attestation.measurement.slice(0, 48)}…`;
    if (attestPolEl) attestPolEl.textContent = plan.enclave_attestation.openshell_policy;

    if (planStepsEl) {
      planStepsEl.innerHTML = '';
      plan.plan.forEach(step => {
        const li = document.createElement('li');
        li.className = 'rounded-xl border border-moss/30 bg-moss/5 p-4';
        const predicted = step.cost_estimate_predicted_usd;
        li.innerHTML = `
          <div class="flex items-baseline justify-between gap-3">
            <span class="font-mono text-ink">step ${step.step} · ${escapeHtml(step.skill)}</span>
            <span class="font-mono text-copper-deep tabular-nums">${fmtMoney(step.cost_estimate_usd)}</span>
          </div>
          <p class="text-caption text-ink-soft mt-1">${escapeHtml(step.why)}</p>
          <p class="text-caption text-ink-soft mt-2">
            <span class="text-ink-50">static</span> ${fmtMoney(step.cost_estimate_usd)}
            · <span class="text-ink-50">predicted</span> ${fmtMoney(predicted.low)}–${fmtMoney(predicted.high)} (n=${predicted.n})
            · <span class="text-verdigris-deep">practiced ✓</span>
          </p>
        `;
        planStepsEl.appendChild(li);
      });
    }

    if (modalTotalEl) modalTotalEl.textContent = fmtMoney(plan.total_cost_estimate_usd);
  }

  function hideModal(): void {
    if (!modalOverlay) return;
    modalOverlay.classList.add('hidden');
    modalOverlay.classList.remove('flex');
    if (modifyBox) modifyBox.classList.add('hidden');
    if (modifyInput) modifyInput.value = '';
  }

  // ── Submit intent ────────────────────────────────────────────
  let _inFlight = false;

  async function handleSubmit(e: Event): Promise<void> {
    e.preventDefault();
    if (_inFlight) return;
    const text = promptInput?.value?.trim() ?? '';
    if (!text) return;
    if (promptInput) promptInput.value = '';
    _inFlight = true;
    clearPanels();
    totalSpent = 0;
    callCount = 0;
    if (bannerCalls) bannerCalls.textContent = '0';
    if (bannerCost) bannerCost.textContent = '$0.0000';
    if (bannerSession) bannerSession.textContent = '...';
    if (bannerStatus) bannerStatus.textContent = 'broker.intent(...) →';

    appendChat('you', text);
    appendChat('broker', 'POST /v1/intent → waiting for plan…');

    try {
      const req: IntentRequest = {
        intent: text,
        context: {
          client_pubkey: 'ed25519:demo_user_pubkey',
          session_id: null,
          max_plan_steps: 5,
          max_budget_usd: 0.50,
          timestamp: Math.floor(Date.now() / 1000),
          nonce: Math.random().toString(36).slice(2),
        },
        signature: 'ed25519:demo_user_sig',
      };
      const plan = await broker.intent(req);
      appendChat('plan', `received · session=${plan.session_id} · ${plan.plan.length} steps · total ${fmtMoney(plan.total_cost_estimate_usd)}`);
      if (bannerSession) bannerSession.textContent = plan.session_id;
      showModal(plan);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      appendChat('system', `error: ${msg}`);
      if (bannerStatus) bannerStatus.textContent = 'error';
    } finally {
      _inFlight = false;
    }
  }

  // ── Approve / Reject / Modify ────────────────────────────────
  async function handleApprove(): Promise<void> {
    if (!currentPlan) return;
    if (bannerStatus) bannerStatus.textContent = 'creating PaymentIntent →';
    appendChat('broker', `POST /v1/stripe.paymentIntents.create · ${fmtMoney(currentPlan.total_cost_estimate_usd)}`);
    const piId = await createPaymentIntent(
      Math.round(currentPlan.total_cost_estimate_usd * 100),
      `VerdantForged plan ${currentPlan.session_id}`
    );
    appendChat('broker', `→ ${piId}`);

    hideModal();
    if (bannerStatus) bannerStatus.textContent = 'broker.approve(plan, pi) →';

    const req: ApprovalRequest = {
      session_id: currentPlan.session_id,
      plan_hash: currentPlan.plan_hash,
      user_approval: true,
      stripe_payment_intent_id: piId,
      user_pubkey: 'ed25519:demo_user_pubkey',
      timestamp: Math.floor(Date.now() / 1000),
      signature: 'ed25519:demo_user_sig',
    };

    try {
      const trace = await broker.approve(req);
      appendChat('plan', `executed ${trace.trace.length} steps · actual ${fmtMoney(trace.totals.actual_cost_usd)}`);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      appendChat('system', `error: ${msg}`);
    }
  }

  async function handleReject(): Promise<void> {
    if (!currentPlan) return;
    appendChat('broker', `POST /v1/reject · ${currentPlan.plan_hash.slice(0, 24)}…`);
    if (currentPlan) {
      try {
        await broker.reject({
          session_id: currentPlan.session_id,
          plan_hash: currentPlan.plan_hash,
          reason: 'user clicked reject',
          timestamp: Math.floor(Date.now() / 1000),
          signature: 'ed25519:demo_user_sig',
        });
      } catch { /* ignore */ }
    }
    hideModal();
    if (bannerStatus) bannerStatus.textContent = 'plan rejected';
  }

  function showModifyBox(): void {
    if (modifyBox) modifyBox.classList.remove('hidden');
    if (modifyInput) {
      modifyInput.focus();
      modifyInput.value = '';
    }
  }

  function hideModifyBox(): void {
    if (modifyBox) modifyBox.classList.add('hidden');
    if (modifyInput) modifyInput.value = '';
  }

  async function handleModifySubmit(): Promise<void> {
    if (!currentPlan) return;
    const reason = modifyInput?.value?.trim() ?? '';
    if (!reason) return;
    appendChat('broker', `POST /v1/modify · "${reason}"`);
    hideModifyBox();
    if (bannerStatus) bannerStatus.textContent = 'broker.modify(...) →';

    const req: ModificationRequest = {
      session_id: currentPlan.session_id,
      parent_plan_hash: currentPlan.plan_hash,
      modification_reason: reason,
      original_intent: currentPlan.plan[0]?.args?._matched_for as string ?? '',
      timestamp: Math.floor(Date.now() / 1000),
    };

    try {
      const planV2 = await broker.modify(req);
      appendChat('plan', `plan_v2 received · parent=${planV2.parent_plan_hash?.slice(0, 24)}… · ${planV2.plan.length} steps`);
      showModal(planV2);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      appendChat('system', `error: ${msg}`);
    }
  }

  // ── Wire everything up ───────────────────────────────────────
  if (promptForm) promptForm.addEventListener('submit', handleSubmit);

  document.querySelector<HTMLButtonElement>('[data-role="modal-approve"]')?.addEventListener('click', handleApprove);
  document.querySelector<HTMLButtonElement>('[data-role="modal-reject"]')?.addEventListener('click', handleReject);
  document.querySelector<HTMLButtonElement>('[data-role="modal-modify"]')?.addEventListener('click', showModifyBox);
  document.querySelector<HTMLButtonElement>('[data-role="modal-close"]')?.addEventListener('click', handleReject);
  document.querySelector<HTMLButtonElement>('[data-role="modify-cancel"]')?.addEventListener('click', hideModifyBox);
  document.querySelector<HTMLButtonElement>('[data-role="modify-submit"]')?.addEventListener('click', handleModifySubmit);

  // ESC closes the modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modalOverlay?.classList.contains('hidden')) {
      handleReject();
    }
  });

  // Init Stripe lazily (so the page is interactive even if Stripe CDN is slow)
  initStripe();
</script>
