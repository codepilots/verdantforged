---
/**
 * index.astro — VerdantForged landing page
 * Apple-clean, scroll-driven single-page. 6 sections, broker-as-product:
 *   Hero · Pillars · HowItWorks · Security (deep dive) · Demo · TryInAgent · Footer
 *
 * Pitch axis: the broker is the product, the four pillars (Attestation,
 * Security, Sandboxing, Payment) are the pitch. The marketplace framing
 * (Provider / Requester / TrustLoop) was removed in the 2026-06-29 pivot.
 * The 3-agent animation (TrustLoop.astro), skill marketplace, and in-browser
 * Pyodide splash were dropped at the same time.
 */
import BaseLayout   from '~/layouts/BaseLayout.astro';
import Hero         from '~/components/Hero.astro';
import Pillars      from '~/components/Pillars.astro';
import HowItWorks   from '~/components/HowItWorks.astro';
import SecurityTable from '~/components/SecurityTable.astro';
import DemoEmbed    from '~/components/DemoEmbed.astro';
import TryInAgent   from '~/components/TryInAgent.astro';
import Footer       from '~/components/Footer.astro';
---

<BaseLayout
  title="VerdantForged — The broker for attested agent execution. SEV-SNP enclaves, end-to-end encryption, fuel-limited sandboxing, Stripe-held escrow."
  description="The broker that runs your agent inside a hardware-attested AMD SEV-SNP enclave. Four pillars: attestation, security, sandboxing, payment. Stripe PaymentIntent verify-then-capture, refund on signed enclave teardown. Live test broker at verdant.codepilots.co.uk."
>
  <main>
    <Hero />

    <!-- Four pillars — the centerpiece -->
    <Pillars />

    <!-- 5-step protocol walkthrough -->
    <HowItWorks />

    <!-- Security deep dive — primitives, validation, attestation checks -->
    <SecurityTable />

    <!-- Live demo — asciinema cast -->
    <DemoEmbed />

    <!-- Install CTA -->
    <TryInAgent />
  </main>

  <Footer />
</BaseLayout>

<script>
  // Global scroll-reveal: any .vf-reveal element not yet visible fades in when it enters viewport.
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { rootMargin: '0px 0px -100px 0px', threshold: 0.05 });

  // Defer to next tick so server-rendered content is in place
  setTimeout(() => {
    document.querySelectorAll('.vf-reveal').forEach((el) => observer.observe(el));
  }, 50);

  // Lenis smooth scroll — wraps native scroll with momentum. Respects prefers-reduced-motion.
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion && (window as any).Lenis) {
    const lenis = new (window as any).Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });
    function raf(time: number) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  }
</script>
